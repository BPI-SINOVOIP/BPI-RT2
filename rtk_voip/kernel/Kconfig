			depends on RTK_VOIP_RX

			config RTK_VOIP_RX_LINUX_UDP_TRAP
				bool "Linux Kernel UDP Trap"
		
			config RTK_VOIP_RX_NETFILTER_HOOK
				bool "Netfilter Hook"
		endchoice
		
		config RTK_VOIP_IPV6_SUPPORT
			bool "VoIP IPv6 Support"

		config RTK_VOIP_PORT_LINK
			bool "Port Link Monitor"

		config RTK_VOIP_QOS
			bool "Enable QoS for VoIP"
			depends on RTK_VOIP_DRIVERS_PCM8972B_FAMILY || RTL_819X_SWCORE || RTL8686NIC
			default n

		config RTK_VOIP_865xC_QOS
			bool
		config RTK_VOIP_WAN_VLAN
			bool
		config RTK_VOIP_QOS
			bool
		config RTK_VOIP_QOS_HEAVYLOAD
			bool

		# ---------------------------------------------------------------------
		# Debug  
		
		comment "Debug"
		
		config RTK_VOIP_CIRCULAR_LOG_DEV
			bool
			default n
			help
				Use circular buffer to log data, and currently it is used to log IOCTL. 

		# ---------------------------------------------------------------------
		# Debug - log IOCTL  
		
		config RTK_VOIP_LOG_IOCTL
			bool "log IOCTL"
			depends on RTK_VOIP_STANDALONE_ARCH || RTK_VOIP_IPC_ARCH_IS_HOST
			select RTK_VOIP_CIRCULAR_LOG_DEV
			help
				Log all IOCTL information into '/dev/voip/log_ioctl'  
		
		config RTK_VOIP_LOG_IOCTL_SIZE
			hex "log IOCTL buffer size"
			default 0x8000
			depends on RTK_VOIP_LOG_IOCTL
		
		choice
			prompt "log IOTCL type"
			default RTK_VOIP_LOG_IOCTL_TYPE_TEXT
			depends on RTK_VOIP_LOG_IOCTL
			
			config RTK_VOIP_LOG_IOCTL_TYPE_TEXT
			bool "Text"
			
			#config RTK_VOIP_LOG_IOCTL_TYPE_BINARY
			#bool "Binary"
		endchoice

		# ---------------------------------------------------------------------
		# TAPI channel remapping

		comment "TAPI channel remapping"

		config RTK_VOIP_TAPI_CH_REMAP
			bool "TAPI channel remapping"
			default n
			help
				TAPI channel remapping.

	endif	
