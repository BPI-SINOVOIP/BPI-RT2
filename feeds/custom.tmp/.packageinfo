Title: Samba 3.6 SMB/CIFS client
Maintainer: Felix Fietkau <nbd@nbd.name>
Source: samba-3.6.25.tar.gz
License: GPL-3.0
LicenseFiles: COPYING
Type: ipkg
Description: Samba 3.6 SMB/CIFS client
https://www.samba.org/
Felix Fietkau <nbd@nbd.name>
@@

Package: samba36-server
Version: 3.6.25-14
Depends: +libc +USE_GLIBC:librt +USE_GLIBC:libpthread 
Conflicts: 
Menu-Depends: 
Provides: 
Section: net
Category: Network
Repository: base
Title: Samba 3.6 SMB/CIFS server
Maintainer: Felix Fietkau <nbd@nbd.name>
Source: samba-3.6.25.tar.gz
License: GPL-3.0
LicenseFiles: COPYING
Type: ipkg
Description:  The Samba software suite is a collection of programs that implements the
 SMB protocol for UNIX systems, allowing you to serve files and printers to
 Windows, NT, OS/2 and DOS clients. This protocol is sometimes also referred
 to as the LanManager or Netbios protocol.
https://www.samba.org/
Felix Fietkau <nbd@nbd.name>
@@
Config:
	choice
	prompt "Account Management"
	default PACKAGE_SAMBA_PDBEDIT
	config PACKAGE_SAMBA_PDBEDIT
	bool "pdbedit"

	config PACKAGE_SAMBA_SMBPASSWD
	bool "smbpasswd"
	endchoice

	config PACKAGE_SAMBA_MAX_DEBUG_LEVEL
		int "Maximum level of compiled-in debug messages"
		depends on PACKAGE_samba36-server || PACKAGE_samba36-client
		default -1
@@

