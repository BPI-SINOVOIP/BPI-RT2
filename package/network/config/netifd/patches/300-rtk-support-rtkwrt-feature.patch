+		cfg->rule_priority = blobmsg_get_u32(cur);
+
+	snprintf(cfg->carrier_mode, sizeof(cfg->carrier_mode)-1, "AUTO");
+	if ((cur = tb[SMUX_ATTR_CARRIER])){
+		snprintf(cfg->carrier_mode, sizeof(cfg->carrier_mode)-1, "%s", (char *) blobmsg_data(cur));
+		if (strcmp(cfg->carrier_mode, "AUTO") && strcmp(cfg->carrier_mode, "MANUAL"))
+		{
+			D(DEVICE, "illegal carrier=%s\n", cfg->carrier_mode);
+			snprintf(cfg->carrier_mode, sizeof(cfg->carrier_mode)-1, "AUTO");
+		}
+	}
+
+	cfg->vid = -1;
+	if ((cur = tb[SMUX_ATTR_VID])){
+		cfg->vid = blobmsg_get_u32(cur);
+		if(cfg->vid < -2 || cfg->vid > 4094) {
+			D(DEVICE, "illegal vid=%d\n", cfg->vid);
+			cfg->vid = -1;
+		}
+	}
+
+	cfg->vpri = -1;
+	if ((cur = tb[SMUX_ATTR_VPRI])){
+		cfg->vpri = blobmsg_get_u32(cur);
+		if(cfg->vpri < -1 || cfg->vpri > 7) {
+			D(DEVICE, "illegal vpri=%d\n", cfg->vpri);
+			cfg->vpri = -1;
+		}
+	}
+
+	cfg->mvid = -1;
+	if ((cur = tb[SMUX_ATTR_MVID])){
+		cfg->mvid = blobmsg_get_u32(cur);
+		if(cfg->mvid < -1 || cfg->mvid > 4094) {
+			D(DEVICE, "illegal mvid=%d\n", cfg->mvid);
+			cfg->mvid = -1;
+		}
+	}
+
+	if ((cur = tb[SMUX_ATTR_UNICAST]))
+		cfg->unicast = blobmsg_get_u8(cur);
+
+	return ret;
+}
+
+static struct device *
+smux_create(const char *name, struct device_type *devtype,
+	struct blob_attr *attr)
+{
+	struct blob_attr *tb[__SMUX_ATTR_MAX];
+	struct blob_attr *tb_dev[__DEV_ATTR_MAX];
+	struct smux_state *sst;
+	struct smux_config *cfg;
+	struct device *dev = NULL;
+
+	sst = calloc(1, sizeof(*sst));
+	if (!sst)
+		return NULL;
+
+	dev = &sst->dev;
+
+	if (device_init(dev, devtype, name) < 0) {
+		device_cleanup(dev);
+		free(sst);
+		return NULL;
+	}
+
+	if (attr) {
+		blobmsg_parse(device_attr_list.params, __DEV_ATTR_MAX, tb_dev,
+			blob_data(attr), blob_len(attr));
+		blobmsg_parse(smux_attrs, __SMUX_ATTR_MAX, tb,
+			blob_data(attr), blob_len(attr));
+
+		device_init_settings(dev, tb_dev);
+		smux_apply_settings(sst, tb);
+
+		cfg = &sst->config;
+		system_smux_add(cfg);
+	}
+
+	dev->config_pending = true;
+
+	sst->set_state = dev->set_state;
+	dev->set_state = smux_set_state;
+
+	return dev;
+}
+
+static enum dev_change_type
+smux_reload(struct device *dev, struct blob_attr *attr)
+{
+	struct smux_state *sst;
+	struct smux_config *cfg;
+	struct blob_attr *tb[__SMUX_ATTR_MAX];
+	struct blob_attr *tb_dev[__DEV_ATTR_MAX];
+	enum dev_change_type ret = DEV_CONFIG_APPLIED;
+	int ret1;
+
+	if (uci_blob_check_equal(dev->config, attr, &smux_attr_list))
+		return DEV_CONFIG_NO_CHANGE;
+
+	if (attr) {
+		sst = container_of(dev, struct smux_state, dev);
+
+		blobmsg_parse(device_attr_list.params, __DEV_ATTR_MAX, tb_dev,
+			blob_data(attr), blob_len(attr));
+		blobmsg_parse(smux_attrs, __SMUX_ATTR_MAX, tb,
+			blob_data(attr), blob_len(attr));
+
+		device_init_settings(dev, tb_dev);
+		ret1 = smux_apply_settings(sst, tb);
+
+		cfg = &sst->config;
+		if(ret1 == 2)
+		{
+			D(DEVICE, "Recreate SMUX interface of %s\n", dev->ifname);
+			system_smux_del(cfg);
+			system_smux_add(cfg);
+		}
+		else
+		{
+			D(DEVICE, "Update SMUX rule of %s\n", dev->ifname);
+			system_smux_update(cfg);
+		}
+	}
+	return ret;
+}
+
+static void __init smux_device_type_init(void)
+{
+	device_type_add(&smux_device_type);
+}
+
+
+int system_smux_del(struct smux_config *scfg)
+{
+	char cmd[128] = {0};
+	int ret=-1;
+
+	if(!scfg->ifname[0])
+	{
+		D(DEVICE, "No interface name\n");
+		return -1;
+	}
+
+	snprintf(cmd, sizeof(cmd), "smuxctl --if-delete %s", scfg->ifname);
+	D(DEVICE, "cmd=%s\n", cmd);
+	ret = system(cmd);
+
+	return ret;
+}
+
+int system_smux_update(struct smux_config *scfg)
+{
+	char cmd[256] = {0}, alias[64];
+	char *p_cmd = NULL;
+	int ret, i;
+
+	snprintf(alias, sizeof(alias), "%s-default", scfg->ifname);
+	for (i=0; i<=SMUX_MAX_TAGS; i++)
+	{
+		sprintf(cmd, "smuxctl --rx --if %s --tags %d --rule-remove-alias %s+", scfg->phydev, i, alias); ret = system(cmd);
+		sprintf(cmd, "smuxctl --tx --if %s --tags %d --rule-remove-alias %s+", scfg->phydev, i, alias); ret = system(cmd);
+		sprintf(cmd, "smuxctl --rx --if %s --tags %d --rule-remove-alias %s+", scfg->ifname, i, alias); ret = system(cmd);
+		sprintf(cmd, "smuxctl --tx --if %s --tags %d --rule-remove-alias %s+", scfg->ifname, i, alias); ret = system(cmd);
+	}
+
+	snprintf(cmd, sizeof(cmd), "smuxctl --if %s --carrier %s", scfg->ifname, scfg->carrier_mode);
+	D(DEVICE, "cmd=%s\n", cmd);
+	ret = system(cmd);
+	if (ret < 0) D(DEVICE, "Error do cmd, ret=%d\n", ret);
+
+	// RX PHYDEV
+	for (i=0; i<=SMUX_MAX_TAGS; i++)
+	{
+		if(scfg->vid != -2)
+		{
+			if (i == 0 && (scfg->vid > 0 || (scfg->vid == 0 && scfg->vpri >= 0)))
+				continue;
+			else if (i > 0 && !(scfg->vid > 0 || (scfg->vid == 0 && scfg->vpri >= 0)))
+				continue;
+		}
+
+		p_cmd = cmd;
+		p_cmd += sprintf(p_cmd, "smuxctl --rx --if %s", scfg->phydev);
+
+		if (scfg->vid > 0)
+			p_cmd += sprintf(p_cmd, " --tags %d --filter-vid %d %d", i, scfg->vid, i);
+		else if (scfg->vid == 0 && scfg->vpri >= 0)
+			p_cmd += sprintf(p_cmd, " --tags %d --filter-vid %d %d --filter-priority %d %d", i, scfg->vid, i, scfg->vpri, i);
+		else if (scfg->vid == -2)
+			p_cmd += sprintf(p_cmd, " --tags %d",i);
+		else
+			p_cmd += sprintf(p_cmd, " --tags 0");
+
+		if (scfg->unicast)
+			p_cmd += sprintf(p_cmd, " --filter-unicast-mac 1");
+
+		if (scfg->rule_priority > 0)
+			p_cmd += sprintf(p_cmd, " --rule-priority %d", scfg->rule_priority);
+
+		p_cmd += sprintf(p_cmd, " --set-rxif %s --rule-alias %s-rx-phy --target ACCEPT --rule-append",
+								scfg->ifname, alias);
+
+		D(DEVICE, "cmd=%s\n", cmd);
+		ret = system(cmd);
+		if (ret < 0) D(DEVICE, "Error do cmd, ret=%d\n", ret);
+	}
+
+	// RX MVLAN
+	if (scfg->mvid > 0 && scfg->mvid != scfg->vid)
+	{
+		for (i=1; i<=SMUX_MAX_TAGS; i++)
+		{
+			p_cmd = cmd;
+			p_cmd += sprintf(p_cmd, "smuxctl --rx --if %s", scfg->phydev);
+			p_cmd += sprintf(p_cmd, " --tags %d --filter-vid %d %d --filter-multicast", i, scfg->mvid, i);
+			if (scfg->vid > 0)
+				p_cmd += sprintf(p_cmd, " --set-vid %d %d", scfg->vid, i);
+			else if (scfg->vid == 0 && scfg->vpri >= 0)
+				p_cmd += sprintf(p_cmd, " --set-vid 0 %d --set-priority %d %d", i, scfg->vpri, i);
+			else
+				p_cmd += sprintf(p_cmd, " --pop-tag");
+
+			if (scfg->rule_priority > 0)
+			p_cmd += sprintf(p_cmd, " --rule-priority %d", scfg->rule_priority);
+
+			p_cmd += sprintf(p_cmd, " --set-rxif %s --rule-alias %s-rx-mvlan --target ACCEPT --rule-append",
+									scfg->ifname, alias);
+
+			D(DEVICE, "cmd=%s\n", cmd);
+			ret = system(cmd);
+			if (ret < 0) D(DEVICE, "Error do cmd, ret=%d\n", ret);
+		}
+	}
+
+	if (scfg->vid > 0 || (scfg->vid == 0 && scfg->vpri >= 0))
+	{
+		for (i=1; i<=SMUX_MAX_TAGS; i++)
+		{
+			// RX
+			p_cmd = cmd;
+			p_cmd += sprintf(p_cmd, "smuxctl --if %s --rx --tags %d --filter-vid %d %d", scfg->ifname, i, scfg->vid, i);
+			p_cmd += sprintf(p_cmd, " --pop-tag --rule-alias %s-rx --rule-append ", alias);
+
+			D(DEVICE, "cmd=%s\n", cmd);
+			ret = system(cmd);
+			if (ret < 0) D(DEVICE, "Error do cmd, ret=%d\n", ret);
+		}
+
+		//TX
+		for (i=0; i<=SMUX_MAX_TAGS; i++)
+		{
+			p_cmd = cmd;
+			p_cmd += sprintf(p_cmd, "smuxctl --if %s --tx --tags %d", scfg->ifname, i);
+
+			if (i == 0)
+				p_cmd += sprintf(p_cmd, " --push-tag");
+
+			p_cmd += sprintf(p_cmd, " --set-vid %d %d ", scfg->vid, (i==0)?i+1:i);
+
+			if (scfg->vpri >= 0)
+				p_cmd += sprintf(p_cmd, " --set-priority %d %d", scfg->vpri, (i==0)?i+1:i);
+
+			p_cmd += sprintf(p_cmd, " --target ACCEPT --rule-alias %s-tx --rule-append", alias);
+
+			D(SYSTEM, "cmd=%s\n", cmd);
+			ret = system(cmd);
+			if (ret < 0) D(DEVICE, "Error do cmd, ret=%d\n", ret);
+		}
+	}
+	return 0;
+}
+
+int system_smux_add(struct smux_config *scfg)
+{
+	char cmd[256] = {0};
+	int ret;
+
+	if(!scfg->ifname[0] && !scfg->phydev[0])
+	{
+		D(DEVICE, "No interface name\n");
+		return -1;
+	}
+
+	snprintf(cmd, sizeof(cmd), "smuxctl --if-create-name %s %s --set-if-rsmux --carrier %s",
+								scfg->phydev, scfg->ifname, scfg->carrier_mode);
+
+	D(DEVICE, "cmd=%s\n", cmd);
+	ret = system(cmd);
+	if (ret < 0)
+		return -1;
+
+	ret = system_smux_update(scfg);
+
+	return ret;
+}
