+static int
+static_update_link(struct static_proto_state *state, struct blob_attr *data, struct blob_attr **tb)
+{
+	struct interface_proto_state *proto = &state->proto;
+	struct interface *iface = proto->iface;
+	struct blob_attr *cur;
+	struct device *dev;
+	const char *devname;
+	bool addr_ext = false;
+	bool keep = false;
+	int dev_create = 1;
+
+	netifd_log_message(L_NOTICE, "Interface do %s for '%s'\n", __FUNCTION__, iface->name);
+
+	if ((cur = tb[STATIC_NOTIFY_KEEP]) != NULL)
+		keep = blobmsg_get_bool(cur);
+
+	// we don't know what it will cause for dev_create = 2
+	if ((cur = tb[STATIC_NOTIFY_ADDR_EXT]) != NULL) {
+		addr_ext = blobmsg_get_bool(cur);
+		if (addr_ext)
+			dev_create = 2;
+	}
+
+	if (iface->state != IFS_UP || !iface->l3_dev.dev)
+		keep = false;
+
+	netifd_log_message(L_NOTICE, "Interface do %s for '%s' keep=%s\n", __FUNCTION__, iface->name, keep ? "true" : "false");
+	D(INTERFACE, "%s keep=%s dev_create %d !!\n", iface->name, keep ? "true" : "false", dev_create);
+	/* TODO:below code for !keep is reference from proto_shell_update_link(), we don't assure if it can
+	 * work well.
+	 */
+
+	if (!keep) {
+		dev = iface->main_dev.dev;
+		if (tb[STATIC_NOTIFY_IFNAME]) {
+			keep = false;
+			devname = blobmsg_data(tb[STATIC_NOTIFY_IFNAME]);
+			if (tb[STATIC_NOTIFY_TUNNEL])
+				;
+				//TODO dev = proto_shell_create_tunnel(devname, tb[STATIC_NOTIFY_TUNNEL]);
+			else
+				dev = device_get(devname, dev_create);
+		}
+
+		if (!dev)
+			return UBUS_STATUS_INVALID_ARGUMENT;
+
+		interface_set_l3_dev(iface, dev);
+		if (device_claim(&iface->l3_dev) < 0)
+			return UBUS_STATUS_UNKNOWN_ERROR;
+
+		device_set_present(dev, true);
+	}
+
+	/* Not sure if it's necessary */
+	interface_update_start(iface, keep);
+
+	/* It seems that static wan always be link up, so if user don't want to keep origin info,
+	 * we just flush its IP and dns info etc...
+	 * */
+#if 0
+	if (!keep)
+		interface_ip_flush(&iface->proto_ip);
+#endif
+	//proto_apply_ip_settings(iface, data, addr_ext);
+	proto_apply_static_ip_settings(iface, data);
+
+	if ((cur = tb[STATIC_NOTIFY_ROUTES]) != NULL)
+		proto_shell_parse_route_list(iface, cur, false);
+
+	if ((cur = tb[STATIC_NOTIFY_ROUTES6]) != NULL)
+		proto_shell_parse_route_list(iface, cur, true);
+
+	if ((cur = tb[STATIC_NOTIFY_NEIGHBORS]) != NULL)
+		proto_shell_parse_neighbor_list(iface, cur, false);
+
+	if ((cur = tb[STATIC_NOTIFY_NEIGHBORS6]) != NULL)
+		proto_shell_parse_neighbor_list(iface, cur, true);
+
+	if ((cur = tb[STATIC_NOTIFY_DNS]))
+		interface_add_dns_server_list(&iface->proto_ip, cur);
+
+	if ((cur = tb[STATIC_NOTIFY_DNS_SEARCH]))
+		interface_add_dns_search_list(&iface->proto_ip, cur);
+
+	//TODO
+#if 0
+	if ((cur = tb[STATIC_NOTIFY_DATA]))
+		proto_shell_parse_data(iface, cur);
+#endif
+
+	interface_update_complete(iface);
+
+	return 0;
+}
+
+static int
+proto_static_run_command(struct static_proto_state *state, struct blob_attr **tb)
+{
+	static char *argv[64];
+	static char *env[32];
+
+	if (state->sm != S_SETUP)
+		return UBUS_STATUS_PERMISSION_DENIED;
+
+	if (!tb[STATIC_NOTIFY_COMMAND])
+		goto error;
+
+	if (!fill_string_list(tb[STATIC_NOTIFY_COMMAND], argv, ARRAY_SIZE(argv)))
+		goto error;
+
+	if (!fill_string_list(tb[STATIC_NOTIFY_ENV], env, ARRAY_SIZE(env)))
+		goto error;
+
+	netifd_start_process((const char **) argv, (char **) env, &state->proto_task);
+
+	return 0;
+
+error:
+	return UBUS_STATUS_INVALID_ARGUMENT;
+}
+
+static int
+proto_static_kill_command(struct static_proto_state *state, struct blob_attr **tb)
+{
+	unsigned int signal = ~0;
+
+	if (tb[STATIC_NOTIFY_SIGNAL])
+		signal = blobmsg_get_u32(tb[STATIC_NOTIFY_SIGNAL]);
+
+	if (signal > 31)
+		signal = SIGTERM;
+
+	if (state->proto_task.uloop.pending) {
+		kill(state->proto_task.uloop.pid, signal);
+	}
+
+	return 0;
+}
+
+static int
+proto_static_notify_error(struct static_proto_state *state, struct blob_attr **tb)
+{
+	struct blob_attr *cur;
+	char *data[16];
+	int n_data = 0;
+	int rem;
+
+	if (!tb[STATIC_NOTIFY_ERROR])
+		return UBUS_STATUS_INVALID_ARGUMENT;
+
+	blobmsg_for_each_attr(cur, tb[STATIC_NOTIFY_ERROR], rem) {
+		if (n_data + 1 == ARRAY_SIZE(data))
+			goto error;
+
+		if (blobmsg_type(cur) != BLOBMSG_TYPE_STRING)
+			goto error;
+
+		if (!blobmsg_check_attr(cur, false))
+			goto error;
+
+		data[n_data++] = blobmsg_data(cur);
+	}
+
+	if (!n_data)
+		goto error;
+
+	interface_add_error(state->proto.iface, state->proto.handler->name,
+			data[0], (const char **) &data[1], n_data - 1);
+
+	return 0;
+
+error:
+	return UBUS_STATUS_INVALID_ARGUMENT;
+}
+
+static int
+proto_static_shell_notify(struct interface_proto_state *proto, struct blob_attr *attr)
+{
+	struct static_proto_state *state;
+	struct blob_attr *tb[__STATIC_NOTIFY_LAST];
+
+	state = container_of(proto, struct static_proto_state, proto);
+	// D(INTERFACE, "%s  %s !!\n", state->proto.iface->name, blob_get_string(attr));
+	blobmsg_parse(static_notify_attr, __STATIC_NOTIFY_LAST, tb, blob_data(attr), blob_len(attr));
+	if (!tb[STATIC_NOTIFY_ACTION])
+		return UBUS_STATUS_INVALID_ARGUMENT;
+
+	switch(blobmsg_get_u32(tb[STATIC_NOTIFY_ACTION])) {
+		case 0:
+			return static_update_link(state, attr, tb);
+		case 1:
+			return proto_static_run_command(state, tb);
+		case 2:
+			return proto_static_kill_command(state, tb);
+		case 3:
+			return proto_static_notify_error(state, tb);
+		default:
+			return UBUS_STATUS_INVALID_ARGUMENT;
+	}
+}
