+#ifdef CONFIG_RTK_NETIFD
+static void
+update_proto_route(struct vlist_tree *tree,
+			     struct vlist_node *node_new,
+			     struct vlist_node *node_old)
+{
+	struct device_route *route_old, *route_new;
+	bool keep = false;
+
+	route_old = container_of(node_old, struct device_route, node);
+	route_new = container_of(node_new, struct device_route, node);
+
+	if (node_old && node_new)
+		keep = !memcmp(&route_old->nexthop, &route_new->nexthop, sizeof(route_old->nexthop)) &&
+			(route_old->mtu == route_new->mtu) && (route_old->type == route_new->type) &&
+			(route_old->proto == route_new->proto) && !route_old->failed &&
+			!memcmp(&route_old->ifdev, &route_new->ifdev, sizeof(route_old->ifdev));
+
+	if (node_old) {
+		if (!(route_old->flags & DEVADDR_EXTERNAL) && route_old->enabled && !keep)
+			system_del_route(NULL, route_old);
+
+		free(route_old);
+	}
+
+	if (node_new) {
+		if (!(route_new->flags & DEVADDR_EXTERNAL) && !keep)
+			if (system_add_route(NULL, route_new))
+				route_new->failed = true;
+
+		route_new->iface = NULL;
+		route_new->enabled = 1;
+	}
+}
+
+void check_proto_route(struct interface *iface)
+{
+	struct device_route *route;
+	struct device *dev;
+
+	if (!iface) return;
+
+	dev = iface->l3_dev.dev;
+	if (!dev) return;
+
+	vlist_for_each_element(&route_lists, route, node)
+	{
+		if (!route->enabled)
+			continue;
+
+		if(route->ifdev[0] && strcmp(dev->ifname, route->ifdev))
+			continue;
+
+		if (iface->state == IFS_UP)
+		{
+			if (system_add_route(NULL, route))
+				route->failed = true;
+			else
+				route->failed = false;
+		}
+		else
+		{
+			if (!route->failed)
+			{
+				if (route->ifdev[0] || system_add_route(NULL, route))
+					route->failed = true;
+			}
+		}
+	}
+}
+
+struct device_addr *
+find_interface_address(struct interface_ip_settings *ip, struct device_addr *b)
+{
+	struct device_addr *a;
+
+	vlist_for_each_element(&ip->addr, a, node)
+	{
+		if ((a->flags&DEVADDR_FAMILY) == (b->flags&DEVADDR_FAMILY) &&
+			a->mask == b->mask && !memcmp(&a->addr, &b->addr, sizeof(a->addr)))
+			return a;
+	}
+	return NULL;
+}
