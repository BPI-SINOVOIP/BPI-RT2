+#ifdef CONFIG_RTK_NETIFD
+enum {
+	DEV_ADD_NAME,
+	DEV_ADD_TYPE,
+	DEV_ADD_MAX,
+};
+
+static const struct blobmsg_policy dev_add_policy[DEV_ADD_MAX] = {
+	[DEV_ADD_NAME] = { .name = "name", .type = BLOBMSG_TYPE_STRING },
+	[DEV_ADD_TYPE] = { .name = "type", .type = BLOBMSG_TYPE_STRING },
+};
+
+static int
+netifd_handle_add_device(struct ubus_context *ctx, struct ubus_object *obj,
+			struct ubus_request_data *req, const char *method,
+			struct blob_attr *msg)
+{
+	struct device *dev = NULL;
+	struct blob_attr *tb[DEV_ADD_MAX];
+	const char *name = NULL, *type = NULL;
+	struct device_type *devtype = NULL;
+
+	blobmsg_parse(dev_add_policy, DEV_ADD_MAX, tb, blob_data(msg), blob_len(msg));
+
+	name = blobmsg_get_string(tb[DEV_ADD_NAME]);
+	if(!name || device_find(name)) return UBUS_STATUS_INVALID_ARGUMENT;
+
+	type = blobmsg_get_string(tb[DEV_ADD_TYPE]);
+	if(type) devtype = device_type_get(type);
+
+	if (devtype)
+	{
+		dev = device_create(name, devtype, msg);
+	}
+	else
+	{
+		dev = device_get(name, 1);
+		if(dev) device_apply_config(dev, dev->type, msg);
+	}
+
+	if (dev)
+	{
+		dev->current_config = true;
+		return UBUS_STATUS_OK;
+	}
+
+	return UBUS_STATUS_UNKNOWN_ERROR;
+}
+
+enum {
+	DEV_DEL_NAME,
+	DEV_DEL_MAX,
+};
+
+static const struct blobmsg_policy dev_del_policy[DEV_DEL_MAX] = {
+	[DEV_DEL_NAME] = { .name = "name", .type = BLOBMSG_TYPE_STRING },
+};
+
+static int
+netifd_handle_del_device(struct ubus_context *ctx, struct ubus_object *obj,
+			struct ubus_request_data *req, const char *method,
+			struct blob_attr *msg)
+{
+	struct device *dev = NULL;
+	struct blob_attr *tb[DEV_DEL_MAX];
+	const char *name = NULL;
+
+	blobmsg_parse(dev_del_policy, DEV_DEL_MAX, tb, blob_data(msg), blob_len(msg));
+
+	name = blobmsg_get_string(tb[DEV_DEL_NAME]);
+	if(!name) return UBUS_STATUS_INVALID_ARGUMENT;
+	if(!(dev = device_find(name))) return UBUS_STATUS_NOT_FOUND;
+	dev->current_config = false;
+	device_free_unused();
+
+	return UBUS_STATUS_OK;
+}
+#endif
