+		}
+
+		if(iface->dhcpv4_event.uloop.fd < 0 || dhcpv4_server_event.uloop.fd != iface->dhcpv4_event.uloop.fd)
+		{
+			dhcpv4_server_event_ref++;
+			memcpy(&iface->dhcpv4_event, &dhcpv4_server_event, sizeof(dhcpv4_server_event));
+		}
+
+		ret = setup_dhcpv4_addresses(iface);
+	} else {
+		while (!list_empty(&iface->dhcpv4_assignments))
+			free_assignment(list_first_entry(&iface->dhcpv4_assignments,
