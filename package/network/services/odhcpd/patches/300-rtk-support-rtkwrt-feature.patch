+			if (setsockopt(ra_server_event.uloop.fd, IPPROTO_IPV6, IPV6_RECVPKTINFO,
+					   &val, sizeof(val)) < 0) {
+				syslog(LOG_ERR, "setsockopt(IPV6_RECVPKTINFO): %m");
+				ret = -1;
+				goto out;
+			}
+
+			if (setsockopt(ra_server_event.uloop.fd, IPPROTO_IPV6, IPV6_RECVHOPLIMIT,
+					   &val, sizeof(val)) < 0) {
