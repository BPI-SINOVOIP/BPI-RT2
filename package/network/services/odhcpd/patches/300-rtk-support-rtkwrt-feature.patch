+
+			val = IPTOS_PREC_INTERNETCONTROL;
+			if (setsockopt(dhcpv4_server_event.uloop.fd, IPPROTO_IP, IP_TOS,
+						&val, sizeof(val)) < 0) {
+				syslog(LOG_ERR, "setsockopt(IP_TOS): %m");
+				ret = -1;
+				goto out;
+			}
+
+			val = IP_PMTUDISC_DONT;
+			if (setsockopt(dhcpv4_server_event.uloop.fd, IPPROTO_IP, IP_MTU_DISCOVER,
+						&val, sizeof(val)) < 0) {
+				syslog(LOG_ERR, "setsockopt(IP_MTU_DISCOVER): %m");
+				ret = -1;
+				goto out;
+			}
+
+			/*if (setsockopt(dhcpv4_server_event.uloop.fd, SOL_SOCKET, SO_BINDTODEVICE,
+						iface->ifname, strlen(iface->ifname)) < 0) {
+				syslog(LOG_ERR, "setsockopt(SO_BINDTODEVICE): %m");
+				ret = -1;
+				goto out;
+			}*/
+
+#ifdef SO_RCVMARK
+			val = 1;
+			if (setsockopt(dhcpv4_server_event.uloop.fd, SOL_SOCKET, SO_RCVMARK,
+						&val, sizeof(val)) < 0) {
+				syslog(LOG_ERR, "setsockopt(SO_RCVMARK): %m");
