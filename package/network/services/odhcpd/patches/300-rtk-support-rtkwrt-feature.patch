+			ra_server_event.handle_filter = handle_icmpv6_filter;
+			odhcpd_register(&ra_server_event);
+		}
+
+		if(iface->router_event.uloop.fd < 0 || ra_server_event.uloop.fd != iface->router_event.uloop.fd)
+		{
+			ra_server_event_ref++;
+			memcpy(&iface->router_event, &ra_server_event, sizeof(ra_server_event));
+		}
+		else {
