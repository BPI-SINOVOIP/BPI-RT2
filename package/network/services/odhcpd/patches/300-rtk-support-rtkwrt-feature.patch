+static int handle_dhcpv4_filter(void *addr, void *data, size_t len,
+		struct interface *iface, void *dest, uint32_t mark)
+{
+	struct dhcpv4_message *req = data;
+
+	if (iface->dhcpv4 == MODE_DISABLED)
+		return 0;
+
+	if (len < offsetof(struct dhcpv4_message, options) + 4 ||
+			req->op != DHCPV4_BOOTREQUEST || req->hlen != 6)
+		return 0;
+
+	if(iface->filter_service)
+	{
+		if(iface->filter_mark_mask &&
+			(mark & iface->filter_mark_mask) != iface->filter_mark)
+			return 0;
+		return 2;
+	}
+
+	return 1;
+}
