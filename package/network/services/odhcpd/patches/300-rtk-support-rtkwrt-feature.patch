+		dhcpv4_server_event.uloop.fd = -1;
+		dhcpv4_server_event_ref = 0;
+	}
+
+	return ret;
+
+out:
+	if (ret < 0 && dhcpv4_server_event.uloop.fd >= 0) {
+		close(dhcpv4_server_event.uloop.fd);
+		dhcpv4_server_event.uloop.fd = -1;
+		dhcpv4_server_event_ref = 0;
+	}
+	return ret;
