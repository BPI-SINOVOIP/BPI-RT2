+		}
+	}
+	else
+		syslog(LOG_ERR, "Connect to ubus failed:%m");
+
+rtk_odhcpd_invoke_fail:
+	if (ubus_ctx)
+		ubus_free(ubus_ctx);
+	if (b_tmp)
+		blob_buf_free(b_tmp);
+
+	return ret;
+}
+
+static int compare_address(bool v6, struct odhcpd_ipaddr *a1, struct odhcpd_ipaddr *a2)
+{
+	uint8_t mask;
+	unsigned long ip4mask = 0;
+	struct in6_addr ip6mask;
+
+	mask = (a1->prefix < a2->prefix) ? a1->prefix : a2->prefix;
+	if(v6)
+	{
+		if(mask > 128) return -1;
+		memset(&ip6mask, 0, sizeof(ip6mask));
+		ip6mask.s6_addr32[0] = htonl(mask <= 32 ? 0xffffffff << (32 - mask) : 0xffffffff);
+        ip6mask.s6_addr32[1] = htonl(mask <= 32 ? 0 : mask > 64 ? 0xffffffff : 0xffffffff << (32 - (mask-32)));
+        ip6mask.s6_addr32[2] = htonl(mask <= 64 ? 0 : mask > 96 ? 0xffffffff : 0xffffffff << (32 - (mask-64)));
+        ip6mask.s6_addr32[3] = htonl(mask <= 96 ? 0 : 0xffffffff << (32 - (mask-96)));
+		if (!(((a1->addr.in6.s6_addr32[0] ^ a2->addr.in6.s6_addr32[0]) & ip6mask.s6_addr32[0]) |
+            ((a1->addr.in6.s6_addr32[1] ^ a2->addr.in6.s6_addr32[1]) & ip6mask.s6_addr32[1]) |
+            ((a1->addr.in6.s6_addr32[2] ^ a2->addr.in6.s6_addr32[2]) & ip6mask.s6_addr32[2]) |
+            ((a1->addr.in6.s6_addr32[3] ^ a2->addr.in6.s6_addr32[3]) & ip6mask.s6_addr32[3])))
+		{
+			if(mask == a1->prefix) return 1;
+			else return 0;
+		}
+	}
+	else
+	{
+		if(mask > 32) return -1;
+		ip4mask = htonl(0xffffffff << (32 - mask));
+		if((a1->addr.in.s_addr & ip4mask) == (a2->addr.in.s_addr & ip4mask)){
+			if(mask == a1->prefix) return 1;
+			else return 0;
+		}
+	}
+
+	return -1;
+}
+
+static int filter_subnets(struct odhcpd_ipaddr *paddr, bool v6, struct blob_attr *dict)
+{
+	enum {
+		_NET_ADDRESS,
+		_NET_MASK,
+		_NET_MAX
+	};
+	static const struct blobmsg_policy policy[_NET_MAX] = {
+		[_NET_ADDRESS] = { "address", BLOBMSG_TYPE_STRING },
+		[_NET_MASK] = { "mask", BLOBMSG_TYPE_INT32 },
+	};
+	struct blob_attr *c;
+	struct odhcpd_ipaddr addr2;
+	char *addr_str;
+	uint8_t mask;
+	uint32_t rem;
+
+	if(!dict || !paddr)
+		return 0;
+
+	blobmsg_for_each_attr(c, dict, rem) {
+		struct blob_attr *tb[_NET_MAX];
+		blobmsg_parse(policy, _NET_MAX, tb, blobmsg_data(c), blobmsg_data_len(c));
+
+		if(tb[_NET_ADDRESS] && tb[_NET_MASK])
+		{
+			addr_str = blobmsg_get_string(tb[_NET_ADDRESS]);
+			mask = blobmsg_get_u32(tb[_NET_MASK]);
+			inet_pton((v6)?AF_INET6:AF_INET, addr_str, &addr2.addr.in6);
+			addr2.prefix = mask;
+			if(compare_address(v6, paddr, &addr2) >= 0)
+				return 1;
+		}
+	}
+	return 0;
+}
+
+static int rtk_odhcpd_get_interface_status_info(struct rtk_odhcpd_interface_status *inf_status_msg, const char *name)
+{
+	int ret = 0;
+	char obj_path[64];
+
+	snprintf(obj_path, sizeof(obj_path), "%s.%s",RTK_ODHCPD_NETIFD_IFACE_OBJ, name);
+	ret = rtk_odhcpd_ubus_invoke(obj_path, RTK_ODHCPD_NETIFD_IFACE_METHOD_STATUS, NULL, rtk_odhcpd_ubus_get_interface_status_cb, (void*)inf_status_msg, -1);
+	if (ret == UBUS_STATUS_OK)
+	{
+		if (inf_status_msg->interface_status_msg) {
+			return 0;
+		}
+		else
+			syslog(LOG_WARNING, "No interface status msg on %s!!!", name);
+	}
+	else
+		syslog(LOG_ERR, "ubus invoke status fail:%m");
+
+	return 1;
+}
+
+int ubus_filter_interface_addrs(const char *name, bool v6, int len, struct odhcpd_ipaddr *addrs, struct odhcpd_ipaddr **addrs_cmp, int refresh)
+{
+	struct blob_attr *c;
+	int rem;
+	struct odhcpd_ipaddr *addrs_tmp, *a1;
+	int idx = -1, i;
+	int found = 0;
+	struct blob_attr *tb[IFACE_ATTR_MAX];
+	struct rtk_odhcpd_interface_status inf_status_msg;
+
+	/* nework.interface dump method use dump msg, refresh case(nework.interface status case)
+	 * doesn't use dump msg. */
+	if (!refresh && !dump)
+		return -1;
+
+	if (len == 0 || addrs == NULL)
+		return -1;
+
+	addrs_tmp = (struct odhcpd_ipaddr*)calloc(len, sizeof(struct odhcpd_ipaddr));
+	if (addrs_tmp == NULL)
+		return -1;
+
+	/* nework.interface status case*/
+	if (refresh) {
+		if (rtk_odhcpd_get_interface_status_info(&inf_status_msg, name) == 0) {
+			blobmsg_parse(iface_attrs, IFACE_ATTR_MAX, tb, blobmsg_data(inf_status_msg.interface_status_msg), blobmsg_data_len(inf_status_msg.interface_status_msg));
+			found =1;
+		}
+	}
+	else { //nework.interface dump case
+		blobmsg_for_each_attr(c, dump, rem) {
+			blobmsg_parse(iface_attrs, IFACE_ATTR_MAX, tb, blobmsg_data(c), blobmsg_data_len(c));
+
+			if (!tb[IFACE_ATTR_INTERFACE] || strcmp(name, blobmsg_get_string(tb[IFACE_ATTR_INTERFACE])))
+				continue;
+			found = 1;
+			break;
+		}
+	}
+
+	if (found)
+	{
+		idx = 0;
+		if (v6)
+		{
+			for(i=0; i<len; i++)
+			{
+				a1 = addrs+i;
+				if (filter_subnets(a1, v6, tb[IFACE_ATTR_ADDRESS]) ||
+					filter_subnets(a1, v6, tb[IFACE_ATTR_PREFIX])  ||
+					filter_subnets(a1, v6, tb[IFACE_ATTR_V6PREFIX_ASSIGN]))
+				{
+					memcpy(addrs_tmp+idx, a1, sizeof(struct odhcpd_ipaddr));
+					idx++;
+				}
+			}
+		}
+		else
+		{
+			for(i=0; i<len; i++)
+			{
+				a1 = addrs+i;
+				if(filter_subnets(a1, v6, tb[IFACE_ATTR_V4ADDRESS]))
+				{
+					memcpy(addrs_tmp+idx, a1, sizeof(struct odhcpd_ipaddr));
+					idx++;
+				}
+			}
+		}
+	}
+
+	if (refresh && inf_status_msg.interface_status_msg)
+		free(inf_status_msg.interface_status_msg);
+
+	if (idx <= 0)
+		free(addrs_tmp);
+	else
+	{
+		if(addrs_cmp) *addrs_cmp = addrs_tmp;
+	}
+
+	return idx;
+}
+#endif
 
 int ubus_init(void)
 {
