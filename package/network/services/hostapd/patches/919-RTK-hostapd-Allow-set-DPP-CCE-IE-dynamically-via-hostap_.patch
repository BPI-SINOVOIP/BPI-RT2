From 29980d5941626026c8b50b478b4d38572f81b13e Mon Sep 17 00:00:00 2001
From: "ryan.kuo" <ryan.kuo@realtek.com>
Date: Fri, 10 Feb 2023 14:37:57 +0800
Subject: [PATCH] [hostapd] Allow set DPP CCE IE dynamically via hostap_cli

- Add new command hostap_cli -i <interface> set dpp_configurator_connectivity <0|1>
---
 hostapd/ctrl_iface.c       | 6 ++++++
 src/ap/hostapd.h           | 1 +
 src/ap/ieee802_11_shared.c | 4 ++--
 3 files changed, 9 insertions(+), 2 deletions(-)
 mode change 100644 => 100755 hostapd/ctrl_iface.c
 mode change 100644 => 100755 src/ap/hostapd.h
 mode change 100644 => 100755 src/ap/ieee802_11_shared.c

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
old mode 100644
new mode 100755
index f50fafb..c419a35
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -1586,6 +1586,12 @@ static int hostapd_ctrl_iface_set(struct hostapd_data *hapd, char *cmd)
 		hapd->dpp_resp_max_tries = atoi(value);
 	} else if (os_strcasecmp(cmd, "dpp_resp_retry_time") == 0) {
 		hapd->dpp_resp_retry_time = atoi(value);
+	} else if (os_strcasecmp(cmd, "dpp_configurator_connectivity") == 0) {
+		int val = atoi(value);
+		if (val < 0 || val > 1)
+			return -1;
+		hapd->dpp_configurator_connectivity = val;
+		ieee802_11_update_beacons(hapd->iface);
 #endif /* CONFIG_DPP */
 	} else if (os_strcasecmp(cmd, "setband") == 0) {
 		ret = hostapd_ctrl_iface_set_band(hapd, value);
diff --git a/src/ap/hostapd.h b/src/ap/hostapd.h
old mode 100644
new mode 100755
index a4ea325..43d8a92
--- a/src/ap/hostapd.h
+++ b/src/ap/hostapd.h
@@ -428,6 +428,7 @@ struct hostapd_data {
 	int dpp_chirp_scan_done;
 	int dpp_chirp_listen;
 #endif /* CONFIG_DPP2 */
+	int dpp_configurator_connectivity;
 #ifdef CONFIG_TESTING_OPTIONS
 	char *dpp_config_obj_override;
 	char *dpp_discovery_override;
diff --git a/src/ap/ieee802_11_shared.c b/src/ap/ieee802_11_shared.c
old mode 100644
new mode 100755
index 4bff9e5..5a08b2c
--- a/src/ap/ieee802_11_shared.c
+++ b/src/ap/ieee802_11_shared.c
@@ -873,7 +873,7 @@ u8 * hostapd_eid_owe_trans(struct hostapd_data *hapd, u8 *eid,
 size_t hostapd_eid_dpp_cc_len(struct hostapd_data *hapd)
 {
 #ifdef CONFIG_DPP2
-	if (hapd->conf->dpp_configurator_connectivity)
+	if (hapd->conf->dpp_configurator_connectivity || hapd->dpp_configurator_connectivity)
 		return 6;
 #endif /* CONFIG_DPP2 */
 	return 0;
@@ -885,7 +885,7 @@ u8 * hostapd_eid_dpp_cc(struct hostapd_data *hapd, u8 *eid, size_t len)
 	u8 *pos = eid;
 
 #ifdef CONFIG_DPP2
-	if (!hapd->conf->dpp_configurator_connectivity || len < 6)
+	if ((!hapd->conf->dpp_configurator_connectivity && !hapd->dpp_configurator_connectivity) || len < 6)
 		return pos;
 
 	*pos++ = WLAN_EID_VENDOR_SPECIFIC;
-- 
2.17.1

