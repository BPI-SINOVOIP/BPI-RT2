+		json_end_array(json);
+	}
 	if (mud_url && mud_url[0]) {
 		json_value_sep(json);
 		json_add_string(json, "mudurl", mud_url);
@@ -2340,6 +2362,11 @@ static int dpp_parse_connector(struct dp
 		if (!role || role->type != JSON_STRING) {
 			wpa_printf(MSG_DEBUG, "DPP: Missing netRole string");
