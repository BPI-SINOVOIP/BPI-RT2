 			   "DPP: connector group: groupId='%s' netRole='%s'",
@@ -2487,6 +2514,13 @@ static int dpp_parse_cred_dpp(struct dpp
 	}
 	dpp_debug_print_key("DPP: Received C-sign-key", csign_pub);
 
+	token = json_get_member(cred, "pass");
+	if (!token || token->type != JSON_STRING) {
+		wpa_printf(MSG_DEBUG, "DPP: No passphrase string found");
+	} else {
+		os_memcpy(conf->passphrase, token->string, os_strlen(token->string));
+	}
+
 	ppkey = json_get_member(cred, "ppKey");
