+					  int dpp_multiap_flag,
 					  const char *mud_url, int *opclasses)
 {
 	size_t len, name_len;
 	const char *tech = "infra";
+
+	if (dpp_multiap_flag == 1) {
+		tech = "map";
+	}
+	
 	const char *dpp_name;
 	struct wpabuf *buf, *json;
 	char *csr = NULL;
