From 6f7370ec8349b45ace3d8b7f14ffff7eb348029e Mon Sep 17 00:00:00 2001
From: "lucien.zhliu" <lucien.zhliu@realtek.com>
Date: Mon, 8 Aug 2022 20:19:59 +0800
Subject: [PATCH] [hostapd] update 20210311_hostapd_add_rc4_skip

* to support library openssl with no-rc4 option
---
 src/crypto/crypto_openssl.c | 38 ++++++++++++++++++++++++++++++++++++-
 1 file changed, 37 insertions(+), 1 deletion(-)
 mode change 100644 => 100755 src/crypto/crypto_openssl.c

diff --git a/src/crypto/crypto_openssl.c b/src/crypto/crypto_openssl.c
old mode 100644
new mode 100755
index 82c8576..d872dd1
--- a/src/crypto/crypto_openssl.c
+++ b/src/crypto/crypto_openssl.c
@@ -290,7 +290,43 @@ int rc4_skip(const u8 *key, size_t keylen, size_t skip,
 	     u8 *data, size_t data_len)
 {
 #ifdef OPENSSL_NO_RC4
-	return -1;
+#define S_SWAP(a,b) do { u8 t = S[a]; S[a] = S[b]; S[b] = t; } while(0)
+	
+	u32 i, j, k;
+	u8 S[256], *pos;
+	size_t kpos;
+	
+	/* Setup RC4 state */
+	for (i = 0; i < 256; i++)
+		S[i] = i;
+	j = 0;
+	kpos = 0;
+	for (i = 0; i < 256; i++) {
+		j = (j + S[i] + key[kpos]) & 0xff;
+		kpos++;
+		if (kpos >= keylen)
+			kpos = 0;
+		S_SWAP(i, j);
+	}
+	
+	/* Skip the start of the stream */
+	i = j = 0;
+	for (k = 0; k < skip; k++) {
+		i = (i + 1) & 0xff;
+		j = (j + S[i]) & 0xff;
+		S_SWAP(i, j);
+	}
+	
+	/* Apply RC4 to data */
+	pos = data;
+	for (k = 0; k < data_len; k++) {
+		i = (i + 1) & 0xff;
+		j = (j + S[i]) & 0xff;
+		S_SWAP(i, j);
+		*pos++ ^= S[(S[i] + S[j]) & 0xff];
+	}
+
+	return 0;
 #else /* OPENSSL_NO_RC4 */
 	EVP_CIPHER_CTX *ctx;
 	int outl;
-- 
2.37.1

