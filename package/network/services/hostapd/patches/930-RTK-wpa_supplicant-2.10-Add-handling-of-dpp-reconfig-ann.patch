From 44d3462f6fb39e1949baf3f83243c6521138317f Mon Sep 17 00:00:00 2001
From: "ryan.kuo" <ryan.kuo@realtek.com>
Date: Fri, 10 Feb 2023 18:59:23 +0800
Subject: [PATCH] [wpa_supplicant-2.10] Add handling of dpp reconfig
 announcement

---
 wpa_supplicant/ctrl_iface.c     |  2 +-
 wpa_supplicant/dpp_supplicant.c | 17 +++++++++++++++++
 wpa_supplicant/wpa_cli.c        |  8 ++++++++
 3 files changed, 26 insertions(+), 1 deletion(-)
 mode change 100644 => 100755 wpa_supplicant/ctrl_iface.c

diff --git a/wpa_supplicant/ctrl_iface.c b/wpa_supplicant/ctrl_iface.c
old mode 100644
new mode 100755
index 6b41317..6fe6ae4
--- a/wpa_supplicant/ctrl_iface.c
+++ b/wpa_supplicant/ctrl_iface.c
@@ -12355,7 +12355,7 @@ char * wpa_supplicant_ctrl_iface_process(struct wpa_supplicant *wpa_s,
 	} else if (os_strcmp(buf, "DPP_STOP_CHIRP") == 0) {
 		wpas_dpp_chirp_stop(wpa_s);
 	} else if (os_strncmp(buf, "DPP_RECONFIG ", 13) == 0) {
-		if (wpas_dpp_reconfig(wpa_s, buf + 13) < 0)
+		if (wpas_dpp_reconfig(wpa_s, buf + 12) < 0)
 			reply_len = -1;
 	} else if (os_strncmp(buf, "DPP_CA_SET ", 11) == 0) {
 		if (wpas_dpp_ca_set(wpa_s, buf + 10) < 0)
diff --git a/wpa_supplicant/dpp_supplicant.c b/wpa_supplicant/dpp_supplicant.c
index f444500..080b1a0 100755
--- a/wpa_supplicant/dpp_supplicant.c
+++ b/wpa_supplicant/dpp_supplicant.c
@@ -2201,6 +2201,8 @@ wpas_dpp_rx_reconfig_announcement(struct wpa_supplicant *wpa_s, const u8 *src,
 			"Missing or invalid required Configurator C-sign key Hash attribute");
 		return;
 	}
+	dpp_notify_reconfig_announcement(wpa_s, wpa_s->current_ssid->id, src,
+		freq, csign_hash);
 	wpa_hexdump(MSG_MSGDUMP, "DPP: Configurator C-sign key Hash (kid)",
 		    csign_hash, csign_hash_len);
 	conf = dpp_configurator_find_kid(wpa_s->dpp, csign_hash);
@@ -3901,6 +3903,7 @@ int wpas_dpp_reconfig(struct wpa_supplicant *wpa_s, const char *cmd)
 	struct wpa_ssid *ssid;
 	int iter = 1;
 	const char *pos;
+	int dpp_multi_ap = 0;
 
 	ssid = wpa_config_get_network(wpa_s->conf, atoi(cmd));
 	if (!ssid || !ssid->dpp_connector || !ssid->dpp_netaccesskey ||
@@ -3917,6 +3920,14 @@ int wpas_dpp_reconfig(struct wpa_supplicant *wpa_s, const char *cmd)
 			return -1;
 	}
 
+	pos = os_strstr(cmd, " multi_ap=");
+	if (pos) {
+		dpp_multi_ap = atoi(pos + 10);
+		wpa_printf(MSG_DEBUG, "DPP: reconfig command initiates dpp multi_ap process");
+	} else {
+		wpa_printf(MSG_DEBUG, "DPP: reconfig command initiates normal dpp process");
+	}
+
 	if (wpa_s->dpp_auth) {
 		wpa_printf(MSG_DEBUG,
 			   "DPP: Not ready to start reconfiguration - pending authentication exchange in progress");
@@ -3949,6 +3960,12 @@ int wpas_dpp_reconfig(struct wpa_supplicant *wpa_s, const char *cmd)
 	wpa_s->dpp_chirp_scan_done = 0;
 	wpa_s->dpp_chirp_listen = 0;
 
+	if (dpp_multi_ap == 1) {
+		wpa_s->dpp_multi_ap = 1;
+	} else {
+		wpa_s->dpp_multi_ap = 0;
+	}
+	
 	return eloop_register_timeout(0, 0, wpas_dpp_chirp_next, wpa_s, NULL);
 }
 
diff --git a/wpa_supplicant/wpa_cli.c b/wpa_supplicant/wpa_cli.c
index 5b8031e..39bd232 100755
--- a/wpa_supplicant/wpa_cli.c
+++ b/wpa_supplicant/wpa_cli.c
@@ -3121,6 +3121,11 @@ static int wpa_cli_cmd_dpp_chirp(struct wpa_ctrl *ctrl, int argc,
 	return wpa_cli_cmd(ctrl, "DPP_CHIRP", 1, argc, argv);
 }
 
+static int wpa_cli_cmd_dpp_reconfig(struct wpa_ctrl *ctrl, int argc,
+				 char *argv[])
+{
+	return wpa_cli_cmd(ctrl, "DPP_RECONFIG", 1, argc, argv);
+}
 
 static int wpa_cli_cmd_dpp_stop_chirp(struct wpa_ctrl *ctrl, int argc,
 				      char *argv[])
@@ -3951,6 +3956,9 @@ static const struct wpa_cli_cmd wpa_cli_commands[] = {
 	{ "dpp_stop_chirp", wpa_cli_cmd_dpp_stop_chirp, NULL,
 	  cli_cmd_flag_none,
 	  "= stop DPP chirp" },
+	{ "dpp_reconfig", wpa_cli_cmd_dpp_reconfig, NULL,
+	  cli_cmd_flag_none,
+	  "<id> = start DPP reconfig announcement" },
 #endif /* CONFIG_DPP2 */
 #endif /* CONFIG_DPP */
 	{ "all_bss", wpa_cli_cmd_all_bss, NULL, cli_cmd_flag_none,
-- 
2.17.1

