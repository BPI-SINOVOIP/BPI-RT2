+static int rtw_ctrl_iface_remote_ap(struct hostapd_iface *iface, char *txt)
+{
+	char *opt, *val;
+
+	wpa_printf(MSG_INFO, "rtw_ctrl_iface_remote_ap: %s", txt);
+	for (opt = strtok(txt, " ");
+	     opt;
+		 opt = strtok(NULL, " ")) {
+
+		if ((val = get_option(opt, "freq=")))
+			iface->rtw_remote_ap.freq = atoi(val);
+		else if ((val = get_option(opt, "ht=")))
+			iface->rtw_remote_ap.ht = atoi(val);
+		else if ((val = get_option(opt, "offset=")))
+			iface->rtw_remote_ap.offset = atoi(val);
+		else if ((val = get_option(opt, "width=")))
+			iface->rtw_remote_ap.width = atoi(val);
+		else if ((val = get_option(opt, "cf1=")))
+			iface->rtw_remote_ap.cf1 = atoi(val);
+		else if ((val = get_option(opt, "cf2=")))
+			iface->rtw_remote_ap.cf2 = atoi(val);
+		else
+			break;
+	}
+
+	iface->rtw_remote_ap.valid = 1;
+	return 0;
+}
