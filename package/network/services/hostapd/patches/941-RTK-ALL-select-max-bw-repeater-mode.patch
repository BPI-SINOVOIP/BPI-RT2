+static int rtw_sync_max_chbw(struct hostapd_data *hapd, struct rtw_remote_ap_args* rtw_remote_ap) {
+	u8 oper_chwidth = hostapd_get_oper_chwidth(hapd->iconf);
+	enum chan_width conf_width, max_width;
+
+	if (((oper_chwidth == CHANWIDTH_160MHZ) || (oper_chwidth == CHANWIDTH_80P80MHZ)) &&
+		((rtw_remote_ap->width == CHAN_WIDTH_80P80) || (rtw_remote_ap->width == CHAN_WIDTH_160)))
+		conf_width = rtw_remote_ap->width; // sync remote ap 160Mhz mode (80+80/160)
+	else if (oper_chwidth == CHANWIDTH_160MHZ)
+		conf_width = CHAN_WIDTH_160;
+	else if (oper_chwidth == CHANWIDTH_80P80MHZ)
+		conf_width = CHAN_WIDTH_80P80;
+	else if (oper_chwidth == CHANWIDTH_80MHZ)
+		conf_width = CHAN_WIDTH_80;
+	else if (hapd->iconf->secondary_channel)
+		conf_width = CHAN_WIDTH_40;
+	else if (hapd->iconf->ieee80211n)
+		conf_width = CHAN_WIDTH_20;
+	else
+		conf_width = CHAN_WIDTH_20_NOHT;
+
+	max_width = rtw_remote_ap->width < conf_width ? conf_width : rtw_remote_ap->width;
+
+	wpa_printf(MSG_INFO, "rtw_sync_max_chbw: conf_bw: %d, sync_bw: %d, max_bw: %d", conf_width, rtw_remote_ap->width, max_width);
+
+	hostapd_event_ch_switch(hapd,
+		rtw_remote_ap->freq,
+		rtw_remote_ap->ht == 0 ? hapd->iconf->ieee80211n : rtw_remote_ap->ht,
+		rtw_remote_ap->offset == 0 ? hapd->iconf->secondary_channel : rtw_remote_ap->offset,
+		max_width,
+		rtw_remote_ap->cf1,
+		rtw_remote_ap->cf2,
+		0
+	);
+}
