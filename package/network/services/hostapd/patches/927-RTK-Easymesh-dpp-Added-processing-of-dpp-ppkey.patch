From f703b27abd22037265c754183ce8f831c97bd5b6 Mon Sep 17 00:00:00 2001
From: "ryan.kuo" <ryan.kuo@realtek.com>
Date: Fri, 10 Feb 2023 18:43:51 +0800
Subject: [PATCH] [All][Easymesh-dpp] Added processing of dpp ppkey.

---
 src/common/wpa_ctrl.h           | 1 +
 wpa_supplicant/dpp_supplicant.c | 6 +++++-
 wpa_supplicant/wpa_cli.c        | 4 ++++
 3 files changed, 10 insertions(+), 1 deletion(-)

diff --git a/src/common/wpa_ctrl.h b/src/common/wpa_ctrl.h
index 8789318..3a62452 100755
--- a/src/common/wpa_ctrl.h
+++ b/src/common/wpa_ctrl.h
@@ -203,6 +203,7 @@ extern "C" {
 #define DPP_EVENT_C_SIGN_KEY "DPP-C-SIGN-KEY "
 #define DPP_EVENT_C_SIGN_KEY_STORE "DPP-C-SIGN-KEY-STORE "
 #define DPP_EVENT_PP_KEY "DPP-PP-KEY "
+#define DPP_EVENT_PP_KEY_STORE "DPP-PP-KEY-STORE "
 #define DPP_EVENT_NET_ACCESS_KEY "DPP-NET-ACCESS-KEY "
 #define DPP_EVENT_NET_ACCESS_KEY_STORE "DPP-NET-ACCESS-KEY-STORE "
 #define DPP_EVENT_SERVER_NAME "DPP-SERVER-NAME "
diff --git a/wpa_supplicant/dpp_supplicant.c b/wpa_supplicant/dpp_supplicant.c
index 408b374..f444500 100755
--- a/wpa_supplicant/dpp_supplicant.c
+++ b/wpa_supplicant/dpp_supplicant.c
@@ -1541,7 +1541,11 @@ static int wpas_dpp_handle_config_obj(struct wpa_supplicant *wpa_s,
 			wpa_snprintf_hex(hex, hexlen,
 					 wpabuf_head(conf->pp_key),
 					 wpabuf_len(conf->pp_key));
-			wpa_msg(wpa_s, MSG_INFO, DPP_EVENT_PP_KEY "%s", hex);
+			if (handle_mode == DPP_CONFIG_STORE) {
+				wpa_msg(wpa_s, MSG_INFO, DPP_EVENT_PP_KEY_STORE "%s", hex);
+			} else {
+				wpa_msg(wpa_s, MSG_INFO, DPP_EVENT_PP_KEY "%s", hex);
+			}
 			os_free(hex);
 		}
 	}
diff --git a/wpa_supplicant/wpa_cli.c b/wpa_supplicant/wpa_cli.c
index ae5357f..5b8031e 100755
--- a/wpa_supplicant/wpa_cli.c
+++ b/wpa_supplicant/wpa_cli.c
@@ -4345,6 +4345,8 @@ static void wpa_cli_action_process(const char *msg)
 		wpa_cli_exec(action_file, ifname, pos);
 	} else if (str_starts(pos, DPP_EVENT_C_SIGN_KEY_STORE)) {
 		wpa_cli_exec(action_file, ifname, pos);
+	} else if (str_starts(pos, DPP_EVENT_PP_KEY_STORE)) {
+		wpa_cli_exec(action_file, ifname, pos);
 	} else if (str_starts(pos, DPP_EVENT_NET_ACCESS_KEY_STORE)) {
 		wpa_cli_exec(action_file, ifname, pos);
 	} else if (str_starts(pos, DPP_EVENT_CONNECTOR)) {
@@ -4357,6 +4359,8 @@ static void wpa_cli_action_process(const char *msg)
 		wpa_cli_exec(action_file, ifname, pos);
 	} else if (str_starts(pos, DPP_EVENT_C_SIGN_KEY)) {
 		wpa_cli_exec(action_file, ifname, pos);
+	} else if (str_starts(pos, DPP_EVENT_PP_KEY)) {
+		wpa_cli_exec(action_file, ifname, pos);
 	} else if (str_starts(pos, DPP_EVENT_NET_ACCESS_KEY)) {
 		wpa_cli_exec(action_file, ifname, pos);
 	} else if (str_starts(pos, WPA_EVENT_TERMINATING)) {
-- 
2.17.1

