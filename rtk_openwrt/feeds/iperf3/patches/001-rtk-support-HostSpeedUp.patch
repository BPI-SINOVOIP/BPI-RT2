+
+int iperf_speedup_setup(struct iperf_test *test)
+{
+	return _iperf_speedup_config(test, 0);
+}
+
+static int _do_iperf_speedup_clear(struct iperf_test *test, int mode)
+{
+	struct iperf_stream *sp;
+	
+	if(!test->enable_speedup) return 0;
+	
+	SLIST_FOREACH(sp, &test->streams, streams) {
+		iperf_speedup_del_streams(test, sp);
+    }
+	
+	if(mode == 1)
+	{
+		char buf[512];
+		if((test->role == 'c' && !test->reverse) || (test->role == 's' && test->reverse))
+		{
+			snprintf(buf, sizeof(buf), "echo \"del uploadinfo\" > /proc/HostSpeedUP-Info");	
+				if (test->debug) { printf("===> [%s] %s\n", __FUNCTION__, buf); }
+			system(buf);
+		}
+		return 0;
+	}
+	
+	return _iperf_speedup_config(test, 1);
+}
+
+int iperf_speedup_clear(struct iperf_test *test)
+{
+	return _do_iperf_speedup_clear(test, 0);
+}
+
+int iperf_speedup_clear_stream(struct iperf_test *test)
+{
+	return _do_iperf_speedup_clear(test, 1);
+}
+
+int iperf_speedup_send_cookie(struct iperf_test *test, struct iperf_stream *sp)
+{
+	if(test->protocol->id != Ptcp || !test->enable_speedup || !sp->speedup)
+		return 1;
+	if (test->debug) { printf("===> [%s]\n", __FUNCTION__); }
+	/* Send cookie for verification */
+    if (Nwrite(sp->socket, test->cookie, COOKIE_SIZE, test->protocol->id ) < 0) {
+		if (test->debug) { printf("===> [%s] Send fail\n", __FUNCTION__); }
+        return -1;
+    }
+	return 0;
+}
+
+static int _iperf_speedup_config_streams(struct iperf_test *test, struct iperf_stream *sp, int clear)
+{
+	int len;
+    //struct iperf_stream *sp;
+	char buf[512], *p, addrStr[64];
+
+	if(test->protocol->id != Ptcp) return 1;
+	if(clear && !sp->speedup) return 1;
+	if(!clear && (sp->speedup || !test->enable_speedup)) return 1;
+
+	len = sizeof(buf);
+	p = &buf[0];
+	p += snprintf(p, len-(p-buf), "echo \"%s ", (clear)?"del":"add");
+	if(sp->local_addr.ss_family == AF_INET) 
+	{
+		struct sockaddr_in *paddr;
+		paddr = (struct sockaddr_in *) &sp->local_addr; 
+		//paddr =(struct sockaddr_in *) &sp->remote_addr; 
+		p += snprintf(p, len-(p-buf), " sip %s sport %d ", 
+				inet_ntop(AF_INET, &paddr->sin_addr, addrStr, sizeof(addrStr)),
+				ntohs(paddr->sin_port));
+
+		paddr =(struct sockaddr_in *) &sp->remote_addr; 
+		//paddr = (struct sockaddr_in *) &sp->local_addr; 
+		p += snprintf(p, len-(p-buf), " dip %s dport %d ", 
+				inet_ntop(AF_INET, &paddr->sin_addr, addrStr, sizeof(addrStr)),
+				ntohs(paddr->sin_port));
+	}
+	else if(sp->local_addr.ss_family == AF_INET6) 
+	{
+		struct sockaddr_in6 *paddr6;
+		paddr6 = (struct sockaddr_in6 *)&sp->local_addr;
+		if(IN6_IS_ADDR_V4MAPPED(&paddr6->sin6_addr))
+		{
+			struct in_addr addr = *(((struct in_addr*)(paddr6->sin6_addr.s6_addr+12)));
+			p += snprintf(p, len-(p-buf), " sip %s sport %d ", 
+				inet_ntop(AF_INET, &addr, addrStr, sizeof(addrStr)),
+				ntohs(paddr6->sin6_port));
+		}
+		else 
+		{
+			p += snprintf(p, len-(p-buf), " sip %s sport %d ", 
+					inet_ntop(AF_INET6, &paddr6->sin6_addr, addrStr, sizeof(addrStr)),
+					ntohs(paddr6->sin6_port));
+		}
+	
+		paddr6 = (struct sockaddr_in6 *)&sp->remote_addr;
+		if(IN6_IS_ADDR_V4MAPPED(&paddr6->sin6_addr))
+		{
+			struct in_addr addr = *(((struct in_addr*)(paddr6->sin6_addr.s6_addr+12)));
+			p += snprintf(p, len-(p-buf), " dip %s dport %d ", 
+				inet_ntop(AF_INET, &addr, addrStr, sizeof(addrStr)),
+				ntohs(paddr6->sin6_port));
+		}
+		else
+		{
+			p += snprintf(p, len-(p-buf), " dip %s dport %d ", 
+					inet_ntop(AF_INET6, &paddr6->sin6_addr, addrStr, sizeof(addrStr)),
+					ntohs(paddr6->sin6_port));
+		}
+	}
+	
+	if(((test->role == 'c' && !test->reverse) || (test->role == 's' && test->reverse)) && !clear) 
+	{
+		struct tcp_info info;
+		int ilen;
+		unsigned int wscale;
+		unsigned int snd_mss;
+		ilen = sizeof(info);
+		getsockopt(sp->socket, IPPROTO_TCP, TCP_INFO, &info, (socklen_t *)&ilen);
+		wscale = pow(2, info.tcpi_snd_wscale);
+		snd_mss = info.tcpi_snd_mss;
+		p += snprintf(p, len-(p-buf), " upload 1 snd_wscale %u snd_mss %u ", wscale, snd_mss);
+	}
+	
+	p += snprintf(p, len-(p-buf), "\" > /proc/HostSpeedUP-STREAM");
+	
+	if (test->debug) { printf("===> [%s] %s\n", __FUNCTION__, buf); }
+	system(buf);
+	
+	if(clear) sp->speedup = 0;
+	else sp->speedup = 1;
+	
+	return 0;
+}
+
+int iperf_speedup_add_streams(struct iperf_test *test, struct iperf_stream *sp)
+{
+	return _iperf_speedup_config_streams(test, sp, 0);
+}
+
+int iperf_speedup_del_streams(struct iperf_test *test, struct iperf_stream *sp)
+{
+	return _iperf_speedup_config_streams(test, sp, 1);
+}
+
+static unsigned int _iperf_speedup_getlength(struct iperf_stream *sp)
+{
+	int fd1;
+	struct speedtest_arg pass_arg;
+	
+	memset(&pass_arg, 0, sizeof(pass_arg));
+
+	pass_arg.cmd=1;
+	if(sp->local_addr.ss_family == AF_INET) 
+	{
+		struct sockaddr_in *paddr;
+		paddr = (struct sockaddr_in *) &sp->local_addr; 
+		//paddr =(struct sockaddr_in *) &sp->remote_addr; 
+		memcpy(pass_arg.sip, &paddr->sin_addr, sizeof(paddr->sin_addr));
+		//pass_arg.sport = ntohs(paddr->sin_port);
+		pass_arg.sport = paddr->sin_port;
+		
+		paddr =(struct sockaddr_in *) &sp->remote_addr; 
+		//paddr = (struct sockaddr_in *) &sp->local_addr; 
+		memcpy(pass_arg.dip, &paddr->sin_addr, sizeof(paddr->sin_addr));
+		//pass_arg.dport = ntohs(paddr->sin_port);
+		pass_arg.dport = paddr->sin_port;
+		
+		pass_arg.ip_familly = AF_INET;
+	}
+	else if(sp->local_addr.ss_family == AF_INET6) 
+	{
+		unsigned int ip_familly = AF_INET6;
+		struct sockaddr_in6 *paddr6;
+		paddr6 = (struct sockaddr_in6 *)&sp->local_addr;
+		if(IN6_IS_ADDR_V4MAPPED(&paddr6->sin6_addr)) {
+			struct in_addr addr = *(((struct in_addr*)(paddr6->sin6_addr.s6_addr+12)));
+			memcpy(pass_arg.sip, &addr, sizeof(addr));
+			ip_familly = AF_INET;
+		} else {
+			memcpy(pass_arg.sip, &paddr6->sin6_addr, sizeof(paddr6->sin6_addr));
+		}
+		//pass_arg.sport = ntohs(paddr6->sin6_port);
+		pass_arg.sport = paddr6->sin6_port;
+		
+		paddr6 = (struct sockaddr_in6 *)&sp->remote_addr;
+		if(IN6_IS_ADDR_V4MAPPED(&paddr6->sin6_addr)) {
+			struct in_addr addr = *(((struct in_addr*)(paddr6->sin6_addr.s6_addr+12)));
+			memcpy(pass_arg.dip, &addr, sizeof(addr));
+		} else {
+			memcpy(pass_arg.dip, &paddr6->sin6_addr, sizeof(paddr6->sin6_addr));
+		}
+		//pass_arg.dport = ntohs(paddr6->sin6_port);
+		pass_arg.dport = paddr6->sin6_port;
+
+		pass_arg.ip_familly = ip_familly;
+	}
+
+	fd1 = open(DEV_SPEEDUP_PATH, O_RDWR);
+  	if(fd1 < 0){
+		//fprintf(stderr, "Error!Socket create fail in ethctl.\n"); 
+		return 0;
+  	}
+	
+	if (ioctl(fd1, SIOCSPEEDTEST, &pass_arg) < 0) {
+		//fprintf(stderr, "Error ioctl for SIOCETHTEST\n"); 
+		close(fd1);
+		return 0;
+	}
+	close(fd1);
+	//fprintf(stderr,"[%s %d]datalen:%u\n",__func__,__LINE__,pass_arg.ip_familly);
+	
+	return pass_arg.ip_familly;
+}
+
+unsigned int iperf_speedup_recv(struct iperf_stream *sp)
+{
+	unsigned int r;
+	r = _iperf_speedup_getlength(sp);
+	sp->result->bytes_received += r;
+    sp->result->bytes_received_this_interval += r;
+	
+	return r;
+}
+
+unsigned int iperf_speedup_send(struct iperf_stream *sp)
+{
+	unsigned int r;
+	r = _iperf_speedup_getlength(sp);
+	sp->result->bytes_sent += r;
+    sp->result->bytes_sent_this_interval += r;
+	return r;
+}
+
