{
	"luci-mod-rtk-network-config-easymesh": {
		"description": "Grant access to WiFi Easymesh configuration",
		"read": {
			"file": {
				"/tmp/topology_json": [ "read" ],
				"/tmp/map_channel_scan_report_5G": [ "read" ],
				"/tmp/map_channel_scan_report_2G": [ "read" ],
				"/tmp/map_channel_scan_nr_5G": [ "read" ],
				"/tmp/map_channel_scan_nr_2G": [ "read" ],
				"/etc/wlan/scan.sh": [ "exec" ]
			},
			"uci": [ "firewall", "network", "wireless", "rtkmap" ]
		},
		"write": {
			"file": {
				"/usr/sbin/hostapd_cli -i wlan0 wps_pbc": [ "exec" ],
				"/usr/sbin/hostapd_cli -i wlan1 wps_pbc": [ "exec" ],
				"/tmp/map_channel_scan_report_5G": [ "write" ],
				"/tmp/map_channel_scan_report_2G": [ "write" ],
				"/tmp/map_channel_scan_nr_5G": [ "write" ],
				"/tmp/map_channel_scan_nr_2G": [ "write" ],
				"/tmp/topology_json": [ "write" ]
			},
			"uci": [ "firewall", "network", "wireless", "rtkmap" ]
		}
	}
}
