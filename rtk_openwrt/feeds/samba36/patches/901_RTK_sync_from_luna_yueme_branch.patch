diff --git a/lib/util/system.c b/lib/util/system.c
index 17c05531..194352c8 100755
--- a/lib/util/system.c
+++ b/lib/util/system.c
@@ -21,6 +21,65 @@
 #include "includes.h"
 #include "system/network.h"
 #include "system/filesys.h"
+#ifdef CONFIG_RTK_LIB_MIB
+#include <rtk/options.h>
+#endif
+
+#ifdef CONFIG_CGROUPS
+void setLimit(pid_t pid);
+#endif
+
+#ifdef CONFIG_CGROUPS
+#define CMDBUF_SIZE 128
+void setLimit(pid_t pid){
+	unsigned char cmd_buff[CMDBUF_SIZE];
+
+	memset(cmd_buff, 0x0, sizeof(cmd_buff));
+
+//	snprintf(cmd_buff, 32, "cpulimit -p %d -l 80 &\n", pid);
+//	system(cmd_buff);
+
+	// memory limit
+	snprintf(cmd_buff, CMDBUF_SIZE, "mkdir /sys/fs/cgroup/memory/smbd\n");
+	system(cmd_buff);
+
+	memset(cmd_buff, 0x0, sizeof(cmd_buff));
+	snprintf(cmd_buff, CMDBUF_SIZE, "echo %d > /sys/fs/cgroup/memory/smbd/tasks\n", pid);
+	system(cmd_buff);
+
+	memset(cmd_buff, 0x0, sizeof(cmd_buff));
+	snprintf(cmd_buff, CMDBUF_SIZE, "echo 1 > /sys/fs/cgroup/memory/smbd/cgroup.clone_children\n");
+	system(cmd_buff);
+
+	memset(cmd_buff, 0x0, sizeof(cmd_buff));
+	snprintf(cmd_buff, CMDBUF_SIZE, "echo 83886080 > /sys/fs/cgroup/memory/smbd/cgroup.clone_children\n"); // 80*1024*1024 = 80MBytes
+	system(cmd_buff);
+
+
+	// cpulimit
+	snprintf(cmd_buff, CMDBUF_SIZE, "mkdir /sys/fs/cgroup/cpu/smbd\n");
+	system(cmd_buff);
+
+	memset(cmd_buff, 0x0, sizeof(cmd_buff));
+	snprintf(cmd_buff, CMDBUF_SIZE, "echo %d > /sys/fs/cgroup/cpu/smbd/tasks\n", pid);
+	system(cmd_buff);
+
+	memset(cmd_buff, 0x0, sizeof(cmd_buff));
+	snprintf(cmd_buff, CMDBUF_SIZE, "echo 1 > /sys/fs/cgroup/cpu/smbd/cgroup.clone_children\n");
+	system(cmd_buff);
+
+	memset(cmd_buff, 0x0, sizeof(cmd_buff));
+	snprintf(cmd_buff, CMDBUF_SIZE, "echo 1000000 > /sys/fs/cgroup/cpu/smbd/cpu.rt_period_us\n");
+	system(cmd_buff);
+
+	memset(cmd_buff, 0x0, sizeof(cmd_buff));
+	snprintf(cmd_buff, CMDBUF_SIZE, "echo 700000 > /sys/fs/cgroup/cpu/smbd/cpu.rt_runtime_us\n");
+	system(cmd_buff);
+
+	DEBUG(0,("cmd_buff = [%s]\n", cmd_buff));	
+}
+#endif
+
 
