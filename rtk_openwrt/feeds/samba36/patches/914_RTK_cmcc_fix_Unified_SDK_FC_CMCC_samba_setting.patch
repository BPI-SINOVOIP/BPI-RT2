index efe6988d..12cec519 100755
--- a/lib/util/debug.c
+++ b/lib/util/debug.c
@@ -29,6 +29,39 @@
 #define SYSLOG_FACILITY LOG_DAEMON
 #endif
 
+#ifdef SAMBA_DEBUG
+void _fLog(char *fmt, ...)
+{
+        va_list va;
+        FILE *fp = fopen("/var/tmp/smbd.log", "a");
+        time_t t = time(0); /* LOG */
+
+        if (!fp) return;
+
+        fprintf(fp, " [%d] %02u:%02u  ", getpid(), (t / 60) % 60, t % 60);
+        va_start(va, fmt);
+        vfprintf(fp, fmt, va);
+        va_end(va);
+        fprintf(fp, "\n");
+        fclose(fp);
+}
+
