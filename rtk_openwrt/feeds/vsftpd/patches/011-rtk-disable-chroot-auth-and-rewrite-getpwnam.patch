 /* Difference in timezone from GMT in seconds */
 static long s_timezone;
 
+#if CONFIG_RTK_LIB_MIB
+#define FTP_ACCOUNT_FILE	"/var/passwd.ftp"
+static char line[100];
+static struct passwd passwd;
+static char *pwskip(char *p)
+{
+	while( *p && *p != ':' )
+		++p;
+	if( *p ) *p++ = 0;
+	return(p);
+}
+
+struct passwd * getpwnam(const char *name)
+{
+	FILE *fp;
+	char *p;
+	int found = 0;
+
+	fp = fopen(FTP_ACCOUNT_FILE, "r");
+	if (!fp)
+		return NULL;
+
+	while (1)
+	{
+		memset(line, 0, sizeof(line));
+		if ( (p = fgets(line, sizeof(line), fp)) == NULL )
+			break;
+
+		passwd.pw_name = p;
+		p = pwskip(p);
+
+		if (strcmp(passwd.pw_name, name))
+			continue;
+
+		passwd.pw_passwd = p;
+		p = pwskip(p);
+		passwd.pw_uid = atoi(p);
+		p = pwskip(p);
+		passwd.pw_gid = atoi(p);
+		p = pwskip(p);
+		passwd.pw_gecos = p;
+		p = pwskip(p);
+		passwd.pw_dir = p;
+		p = pwskip(p);
+		passwd.pw_shell = p;
+
+		while(*p && *p != '\n') p++;
+		*p = '\0';
+
+		found = 1;
+		break;
+	}
+	fclose(fp);
+
+	if (found)
+		return (&passwd);
+	else
+		return NULL;
+}
+
+#endif
+
+
