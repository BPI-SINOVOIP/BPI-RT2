+int bulkdata_time_format(time_t ts, char **dst)
+{
+	char time_buf[32] = { 0, 0 };
+	struct tm *t_tm;
+
+	*dst = strdup("0001-01-01T00:00:00+00:00");
+
+	t_tm = localtime(&ts);
+	if (t_tm == NULL)
+		return -1;
+
+	if(strftime(time_buf, sizeof(time_buf), "%Y-%m-%dT%H:%M:%SZ", t_tm) == 0)
+		return -1;
+
+	FREE(*dst);
+	*dst = strdup(time_buf);
+	return 0;
+}
+
+int create_xml_bulkdata_report(struct profile *profile, char **report)
+{
+	char *str1 = NULL, *str2 = NULL, *str3 = NULL;
+	param_data_t *p = NULL;
+	int i = 0, profile_param_number = profile->profile_parameter_number;
+	char *dst1 = NULL, *dst2 = NULL, *manufacturer_oui = NULL, *serial_number = NULL;
+	int res = 0;
+
+	INFO("Total nums of parameters on Profilr: %d", profile->profile_parameter_number);
+
+	bulkdata_time_format(time(NULL), &dst1);
+	vendor_data_t oui_data = { .path = "Device.DeviceInfo.ManufacturerOUI" };
+	res = get_value_single(&oui_data);
+	manufacturer_oui = (res == 0) ? oui_data.p_value : strdup("");
+
+	vendor_data_t sn_data = { .path = "Device.DeviceInfo.SerialNumber" };
+	res = get_value_single(&sn_data);
+	serial_number = (res == 0) ? sn_data.p_value : strdup("");
+
+	asprintf(report, "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
+							"<ipdr:IPDRDoc xmlns:ipdr=\"http://www.ipdr.org/namespaces/ipdr\"\n"
+							"              xmlns=\"urn:broadband-forum-org:ipdr:tr-232-1-0\"\n"
+							"              xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n"
+							"              xsi:schemaLocation=\"urn:broadband-forum-org:ipdr:tr-232-1-0\n"
+							"                  tr-232-1-0-0-serviceSpec.xsd\n"
+							"                  http://www.ipdr.org/namespaces/ipdr\n"
+							"                  http://www.ipdr.org/public/IPDRDoc3.5.1.xsd\"\n"
+							"              docId=\"f81d4fae-7dec-11d0-a765-00a0c91e6bf6\"\n"
+							"              creationTime=\"%s\"\n"
+							"              IPDRRecorderInfo=\"Profile\"\n"
+							"              version=\"3.5.1\">\n", dst1);
+
+	asprintf(&str1, "	<ipdr:IPDR xsi:type=\"BulkDataReport\">\n"
+							"		<OUI>%s</OUI>\n"
+							"		<ProductClass></ProductClass>\n"
+							"		<SerialNumber>%s</SerialNumber>\n"
+							"		<Suspect>false</Suspect>\"\n", manufacturer_oui, serial_number);
+	append_string_to_string(str1, report);
+	FREE(manufacturer_oui);
+	FREE(serial_number);
+	FREE(str1);
+	FREE(dst1);
+
+	for (i = 0; i < profile_param_number; i++) {
+		LIST_HEAD(results_list);
+
+		vendor_data_t ref_data = {
+			.path = profile->profile_parameter[i].reference,
+			.list = &results_list
+		};
+
+		int res = get_value_group(&ref_data);
+		if (res != 0)
+			continue;
+
+		list_for_each_entry(p, &results_list, list) {
+			asprintf(&str2,"		<BulkData>\n"
+						"			<Name>%s</Name>\n"
+						"			<Value>%s</Value>\n"
+						"		</BulkData>\n", profile->profile_parameter[i].reference, p->data);
+			append_string_to_string(str2, report);
+			FREE(str2);
+		}
+
+		bulkdata_free_data_from_list(&results_list);
+	}
+
+	bulkdata_time_format(time(NULL), &dst2);
+	asprintf(&str3,"	</ipdr:IPDR>\n"
+				"	<ipdr:IPDRDoc.End count=\"1\" endTime=\"%s\">\n"
+				"</ipdr:IPDRDoc>\n", dst2);
+	append_string_to_string(str3, report);
+	FREE(dst2);
+	FREE(str3);	
+
+	return 0;
+}
+
 void create_encoding_bulkdata_report(struct profile *profile, char **report)
 {
 	if (strcasecmp(profile->encoding_type, "json") == 0) {
 		create_json_bulkdata_report(profile, report);
 	} else if (strcasecmp(profile->encoding_type, "csv") == 0) {
 		create_csv_bulkdata_report(profile, report);
+	} else if (strcasecmp(profile->encoding_type, "xml") == 0) {
+		create_xml_bulkdata_report(profile, report);
 	}
 }
 
