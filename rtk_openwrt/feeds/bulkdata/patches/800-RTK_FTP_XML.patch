+int ftp_send_message(struct profile *profile, char *msg_out)
+{
+#define LOCAL_FILE      "/tmp/report.txt"
+#define UPLOAD_FILE_AS  "report-uploading.txt"
+//#define RENAME_FILE_TO  "renamed-and-fine.txt"
+
+	char remote_url[1048] = {0};  //fttp_url string limit is 1024. Please refer to set_BulkDataProfile_FileTransferURL(). And string Length of UPLOAD_FILE_AS is 20.
+	struct curl_slist *header_list = NULL;
+	CURLcode res;
+	long http_code = 0;
+	char errbuf[CURL_ERROR_SIZE];
+	FILE *hd_src = NULL;
+	struct stat file_info;
+	unsigned long fsize;
+	static const char buf_1 [] = "RNFR " UPLOAD_FILE_AS;
+	//static const char buf_2 [] = "RNTO " RENAME_FILE_TO;
+
+	/* get a FILE * of the same file and write data to report */
+	hd_src = fopen(LOCAL_FILE, "w+");
+	if (hd_src){
+		fprintf(hd_src, "%s\n", msg_out);
+		fclose(hd_src);
+	}
+
+	/* get the file size of the local file */
+	if(stat(LOCAL_FILE, &file_info)) {
+		printf("Couldn't open '%s': %s\n", LOCAL_FILE, strerror(errno));
+		return -1;
+	}
+	fsize = (unsigned long)file_info.st_size;
+
+	hd_src = fopen(LOCAL_FILE, "rb");
+	if (hd_src == NULL)
+		return -1;
+
+	CURL *curl = curl_easy_init();
+	if (!curl) {
+		if (hd_src) 
+			fclose(hd_src); /* close the local file */
+		return -1;
+	}
+
+	snprintf(remote_url, sizeof(remote_url), "%s/%s", profile->ftp_url, UPLOAD_FILE_AS);
+	INFO("FTP url: %s", remote_url);
+
+	/* build a list of commands to pass to libcurl */
+	header_list = curl_slist_append(header_list, buf_1);
