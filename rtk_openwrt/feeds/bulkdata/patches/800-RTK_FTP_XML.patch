+	curl_easy_cleanup(curl);
+	if (header_list) {
+		curl_slist_free_all(header_list);
+		header_list = NULL;
+	}	
+
+	if (hd_src) fclose(hd_src); /* close the local file */
+	return http_code;
+
+error:
+	curl_easy_cleanup(curl);
+	if (header_list) {
+		curl_slist_free_all(header_list);
+		header_list = NULL;
+	}
+	if (hd_src) fclose(hd_src); /* close the local file */
+	return -1;
