/dts-v1/;
/ {
    description = "fitImage for RTK aarch64 kernel";
    #address-cells = <0x1>;
    images {
        kernel {
            description = "Linux Kernel";
            data = /incbin/("./Image.lzma");
            type = "kernel";
            arch = "arm64";
            os = "linux";
            compression = "lzma";
            load = <0x0>;
            entry = <0x0>;
            hash {
                algo = "sha1";
            };
            signature {
                algo = "sha1,rsa2048";
                key-name-hint = "dev";
                padding ="pss";
            };
        };
        fdt {
              description = "Flattened Device Tree blob";
              data = /incbin/("./board_raw.dtb");
              type = "flat_dt";
              load = <0x01000000>;
              arch = "arm64";
              compression = "none";
              hash {
                algo = "sha1";
              };
                signature{
                    algo = "sha1,rsa2048";
                    key-name-hint = "dev";
                    padding ="pss";
                };
        };
        script {
            description = "Script";
            data = /incbin/("./uboot_verity_script");
            type = "script";
            compression = "none";
            hash {
                algo = "sha1";
            };
            signature {
                algo = "sha1,rsa2048";
                key-name-hint = "dev";
                padding ="pss";
            };
        };
    };
    configurations {
        default = "conf";
        conf {
            description = "Boot Linux kernel with FDT blob ";
            kernel = "kernel";
            fdt = "fdt";
            script = "script";
            hash {
                algo = "sha1";
            };
            signature {
                algo = "sha1,rsa2048";
                key-name-hint = "dev";
                padding ="pss";
                sign-images = "fdt", "kernel", "script";
            };
        };
    };
};
