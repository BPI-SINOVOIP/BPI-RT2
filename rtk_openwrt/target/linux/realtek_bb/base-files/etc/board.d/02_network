. /lib/functions/uci-defaults.sh

if [ -f /lib/functions/interface_config.sh ]; then
	. /lib/functions/interface_config.sh
fi

board_config_update

case "$(board_name)" in

esac

if [ "${INTF_LAN_LISTS}" = "" ]; then 
	INTF_LAN_LISTS="eth0.3 eth0.4 eth0.5"
fi

if [ "${INTF_WAN_LISTS}" = "" ]; then
	INTF_WAN_LISTS="eth0.2"
fi

ucidef_set_interface_lan "${INTF_LAN_LISTS}"
ucidef_set_interface_wan "${INTF_WAN_LISTS}" "dhcp"

board_config_flush

exit 0
