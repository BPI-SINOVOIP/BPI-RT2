. /lib/functions/uci-defaults.sh
if [ -f /lib/functions/interface_config.sh ]; then
	. /lib/functions/interface_config.sh
fi

board_config_update

echo "$(board_name)" > /tmp/_board_name

case "$(board_name)" in

esac

if [ "${INTF_LAN_LISTS}" = "" ]; then 
	INTF_LAN_LISTS="eth0.2 eth0.3 eth0.4 eth0.5"
fi

i=1
for lan in ${INTF_LAN_LISTS}
do
	ucidef_set_led_netdev "lan${i}" "LAN${i}" "LED_EPHY$((i-1))" "${lan}"
	let i++
done

_ucidef_set_led_trigger "power" "Power" "LED_PWR_G" "default-on"

board_config_flush

exit 0
