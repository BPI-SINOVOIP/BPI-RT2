+int _is_pppoe_channel(struct ppp_channel* chan)
+{
+	if(chan->ops ==  &pppoe_chan_ops)
+		return 1;
+	return 0;
+}
+
+int _sync_ppp_dev_feature(struct net_device*ppp_dev, struct ppp_channel* chan)
+{
+	struct pppox_sock *po = pppox_sk(chan->private);
+	struct net_device *pppoeDev = po->pppoe_dev;
+
+	ppp_dev->features |= (pppoeDev->features & (NETIF_F_HW_CSUM | NETIF_F_GRO | NETIF_F_SG | NETIF_F_GSO | NETIF_F_TSO | NETIF_F_TSO6));
+	if(ppp_dev->features & NETIF_F_GSO)
+	{
+		netif_set_gso_max_size(ppp_dev, pppoeDev->gso_max_size);
+	}
+	ppp_dev->hw_features |=  pppoeDev->hw_features;
+	return 0;
+}
