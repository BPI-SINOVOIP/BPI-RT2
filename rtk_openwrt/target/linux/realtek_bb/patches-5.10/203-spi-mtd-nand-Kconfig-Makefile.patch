Index: linux-5.10.138/drivers/mtd/nand/core.c
===================================================================
--- linux-5.10.138.orig/drivers/mtd/nand/core.c
+++ linux-5.10.138/drivers/mtd/nand/core.c
@@ -125,13 +125,33 @@ EXPORT_SYMBOL_GPL(nanddev_isreserved);
  */
 int nanddev_erase(struct nand_device *nand, const struct nand_pos *pos)
 {
+#ifdef CONFIG_NAND_HIDE_BAD
+	extern	int xlat_offset_to_skip_factory_bad(   struct nand_device *nand,  struct nand_pos *pos);
+	struct nand_pos xlat_pos;
+	int ret;
+#endif
+
 	if (nanddev_isbad(nand, pos) || nanddev_isreserved(nand, pos)) {
 		pr_warn("attempt to erase a bad/reserved block @%llx\n",
 			nanddev_pos_to_offs(nand, pos));
 		return -EIO;
 	}
-
+#ifdef CONFIG_NAND_HIDE_BAD
+	{
+		xlat_pos = *pos;
+		ret = xlat_offset_to_skip_factory_bad(nand, &xlat_pos);
+		if(ret == -EINVAL){
+				pr_err("%s: offset xlat exceeds chip size\n",__FUNCTION__);
+				return ret;
+		}
+		if(nanddev_pos_cmp(&xlat_pos, pos) !=0 ){
+				pr_debug("Read xlat: 0x%llx => 0x%llx\n", nanddev_pos_to_offs(nand, pos), nanddev_pos_to_offs(nand, &xlat_pos));
+		}
+		return nand->ops->erase(nand, &xlat_pos);
+	}
+#else
 	return nand->ops->erase(nand, pos);
+#endif
 }
 EXPORT_SYMBOL_GPL(nanddev_erase);
 
