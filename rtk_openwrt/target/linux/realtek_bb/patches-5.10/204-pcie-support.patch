Index: linux-5.10.138/drivers/reset/Kconfig
===================================================================
--- linux-5.10.138.orig/drivers/reset/Kconfig
+++ linux-5.10.138/drivers/reset/Kconfig
@@ -15,6 +15,26 @@ menuconfig RESET_CONTROLLER
 
 if RESET_CONTROLLER
 
+config RESET_CORTINA
+	tristate "CORTINA ACCESS Reset Controller"
+	depends on ARCH_CORTINA
+	help
+	  This option enables support for the internal reset functions for
+	  IP module and peripheral PHYs on the CORTINA-ACCESS SoC Chip.
+
+config GPIO_RESET_CONTROLLER
+	tristate "GPIO reset controller"
+	help
+	  Reset controller using GPIO lines
+	
+	  There are two main methods of using this controller:
+	  * As a reset controller within the reset framework allowing device
+	  drivers to request a hardware reset of their devices.
+	  * As a standalone driver performing reset at boot or upon userspace
+	  request (via sysfs)
+	  The second method is suitable for devices on discoverable busses
+	  (SDIO, USB)+config GPIO_RESET_CONTROLLER
+
 config RESET_A10SR
 	tristate "Altera Arria10 System Resource Reset"
 	depends on MFD_ALTERA_A10SR
Index: linux-5.10.138/drivers/reset/Makefile
===================================================================
--- linux-5.10.138.orig/drivers/reset/Makefile
+++ linux-5.10.138/drivers/reset/Makefile
@@ -1,6 +1,8 @@
 # SPDX-License-Identifier: GPL-2.0
 obj-y += core.o
 obj-y += hisilicon/
+obj-$(CONFIG_GPIO_RESET_CONTROLLER) += reset-gpio.o
+obj-$(CONFIG_RESET_CORTINA) += reset-ca77xx.o
 obj-$(CONFIG_ARCH_STI) += sti/
 obj-$(CONFIG_ARCH_TEGRA) += tegra/
 obj-$(CONFIG_RESET_A10SR) += reset-a10sr.o
Index: linux-5.10.138/drivers/pinctrl/Kconfig
