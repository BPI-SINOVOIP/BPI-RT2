 obj-$(CONFIG_PCI_IMX6) += pci-imx6.o
Index: linux-5.10.138/drivers/phy/Kconfig
===================================================================
--- linux-5.10.138.orig/drivers/phy/Kconfig
+++ linux-5.10.138/drivers/phy/Kconfig
@@ -16,6 +16,14 @@ config GENERIC_PHY
 	  phy users can obtain reference to the PHY. All the users of this
 	  framework should select this config.
 
+config PHY_TAURUS
+	tristate "Realtek Taurus PHY driver"
+	depends on OF && (ARCH_CORTINA || COMPILE_TEST)
+	select GENERIC_PHY
+	help
+	  Enable this to support the Realtek Taurus PHY.
+	  If unsure, say N.
+
 config GENERIC_PHY_MIPI_DPHY
 	bool
 	help
