Index: linux-5.10.138/drivers/gpio/Kconfig
===================================================================
--- linux-5.10.138.orig/drivers/gpio/Kconfig
+++ linux-5.10.138/drivers/gpio/Kconfig
@@ -202,6 +202,14 @@ config GPIO_BRCMSTB
 	help
 	  Say yes here to enable GPIO support for Broadcom STB (BCM7XXX) SoCs.
 
+config GPIO_CA77XX
+	bool "Cortina Access CA77XX GPIO controller"
+	depends on ARCH_CORTINA
+	select IRQ_DOMAIN
+	select GPIOLIB_IRQCHIP
+	help
+	  Say yes here to support Cortina Access CA77XX GPIOs
+
 config GPIO_CADENCE
 	tristate "Cadence GPIO support"
 	depends on OF_GPIO
