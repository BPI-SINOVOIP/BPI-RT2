Index: linux-5.10.138/drivers/pci/controller/dwc/Kconfig
===================================================================
--- linux-5.10.138.orig/drivers/pci/controller/dwc/Kconfig
+++ linux-5.10.138/drivers/pci/controller/dwc/Kconfig
@@ -82,6 +82,16 @@ config PCIE_DW_PLAT_EP
 	  order to enable device-specific features PCI_DW_PLAT_EP must be
 	  selected.
 
+config PCIE_CA
+	tristate "Cortina PCIe controller"
+	depends on ARCH_CORTINA
+	depends on PCI && PCI_MSI_IRQ_DOMAIN
+	select PCIE_DW_HOST
+	select PCI_MSI_ARCH_FALLBACKS
+	help
+	  Say Y here if you want PCIE controller support on Cortina Access
+	  SoCs.
+
 config PCI_EXYNOS
 	bool "Samsung Exynos PCIe controller"
 	depends on SOC_EXYNOS5440 || COMPILE_TEST
