+	ct = nf_ct_get(skb, &ctinfo);
+	
+	if(!(ct && (ctinfo == IP_CT_NEW || ctinfo == IP_CT_RELATED ||
+			    ctinfo == IP_CT_RELATED_REPLY)))
+		return XT_CONTINUE;
+				
+	if(ct->status & IPS_DST_NAT /*IPS_DST_NAT_DONE*/) return XT_CONTINUE;
+
+	reply_tuple = &ct->tuplehash[IP_CT_DIR_REPLY].tuple;
+
+	if (memcmp(&reply_tuple->src.u3.ip6, &ipv6_hdr(skb)->daddr, sizeof(reply_tuple->src.u3.ip6))) 
+	{
+		memcpy(&reply_tuple->src.u3.ip6, &ipv6_hdr(skb)->daddr, sizeof(reply_tuple->src.u3.ip6));
+		ct->status |= (IPS_DST_NAT /*| IPS_DST_NAT_DONE*/);
+		
+		if (nfct_help(ct)){
+			nfct_seqadj_ext_add(ct);
+		}
+	}
+
+	return XT_CONTINUE;
+}
