+static unsigned int ip6t_snpt_conntrack(struct sk_buff *skb, const struct xt_action_param *par)
+{
+	enum ip_conntrack_info ctinfo;
+	struct nf_conn *ct;
+	struct nf_conntrack_tuple *reply_tuple;
+
+	ct = nf_ct_get(skb, &ctinfo);
+	
+	if(!(ct && (ctinfo == IP_CT_NEW || ctinfo == IP_CT_RELATED ||
+			    ctinfo == IP_CT_RELATED_REPLY)))
+		return XT_CONTINUE;
+				
+	if(ct->status & IPS_SRC_NAT /*IPS_SRC_NAT_DONE*/) return XT_CONTINUE;
+
+	reply_tuple = &ct->tuplehash[IP_CT_DIR_REPLY].tuple;
+
+	if (memcmp(&reply_tuple->dst.u3.ip6, &ipv6_hdr(skb)->saddr, sizeof(reply_tuple->dst.u3.ip6))) 
+	{
+		memcpy(&reply_tuple->dst.u3.ip6, &ipv6_hdr(skb)->saddr, sizeof(reply_tuple->dst.u3.ip6));
+		ct->status |= (IPS_SRC_NAT /*| IPS_SRC_NAT_DONE*/);
+		
+		if (nfct_help(ct)){
+			nfct_seqadj_ext_add(ct);
+		}
+	}
+
+	return XT_CONTINUE;
+}
+
+static unsigned int ip6t_dnpt_conntrack(struct sk_buff *skb, const struct xt_action_param *par)
+{
+	enum ip_conntrack_info ctinfo;
