+						if (dec_bw[i] == CHANNEL_WIDTH_20)
+							dec_offset[i] = CHAN_OFFSET_NO_EXT;
+						break;
+					}
+				}
+				/* if no larger bw is available, use remote bw */
+				if (j == u_bw) {
+					dec_bw[i] = u_bw;
