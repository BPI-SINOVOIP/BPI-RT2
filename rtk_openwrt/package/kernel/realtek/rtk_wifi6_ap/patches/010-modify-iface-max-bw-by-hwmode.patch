@@ -7198,7 +7198,7 @@ u16 rtw_ap_chbw_decision(_adapter *adapter, u16 ifbmp, u16 excl_ifbmp
 	u16 ifbmp_ch_changed = 0;
 	bool ifbmp_all_mesh = 0;
 	_adapter *iface;
-	int i;
+	int i, j;
 	int if_idx = adapter->iface_id;
 
 	ifbmp_others >>= (16 - dvobj->iface_nums);
@@ -7408,10 +7408,21 @@ u16 rtw_ap_chbw_decision(_adapter *adapter, u16 ifbmp, u16 excl_ifbmp
 			if (req_ch == 0 && dec_bw[i] > u_bw
 				&& rtw_chset_is_dfs_chbw(chset, dec_ch[i], dec_bw[i], dec_offset[i])
 			) {
-				/* request comes from upper layer, prevent from additional channel waiting */
-				dec_bw[i] = u_bw;
-				if (dec_bw[i] == CHANNEL_WIDTH_20)
-					dec_offset[i] = CHAN_OFFSET_NO_EXT;
+				/* request comes from upper layer, shrink the bandwidth until not cover dfs range */
