MAP_CONF_TEMPLATE = "/etc/multiap.conf"
MAP_SETMIB_CONF = "/var/multiap_setmib.conf"

DPP_CSIGN_KEY_PATH = "/tmp/dpp_csign_key"
DPP_NET_ACCESS_KEY_PATH = "/tmp/dpp_netaccess_key"
DPP_PRIVACY_PROTECTION_KEY_PATH = "/tmp/dpp_pp_key"
DPP_CONNECTOR_PATH_1905 = "/tmp/dpp_map_conn"
DPP_AKM_PATH = "/tmp/dpp_akm"
DPP_CONNECTOR_PATH = "/tmp/dpp_"

local function get_prev_mode(radio_name)
  uci:load("wireless")
  local prev_htmode = uci:get("wireless", radio_name, "htmode")
  if not prev_htmode then return nil end
  return prev_htmode:sub(prev_htmode:find("%u+"))
end

local function _write_dpp_creds(conf)
  local function _write_radio_dpp_creds(conf, radio)
    if conf then
      for _, v in ipairs(conf["_BSS_DATAS"]) do
        bss_name = "default_radio" .. radio .. v.bss_index
        if tonumber(v.authentication_type) == AUTH_WPA2_WPA3_DPP and tonumber(v.bss_index) ~= 5 then
          -- vxd should receive its akm and conn from wpas event instead
          ifname = uci:get("wireless", bss_name, "ifname")
          filename = DPP_AKM_PATH.."_"..ifname
          fwrite(filename, "dpp+psk+sae")
          if v.signed_connector then
            filename = DPP_CONNECTOR_PATH..ifname.."_conn"
            fwrite(filename, v.signed_connector)
          end
        end
      end
    end
  end

  local conf_dpp = conf.dpp
  if not conf_dpp then return end

  -- write dpp keys into tmp files
  if conf_dpp["signed_connector_1905"] then
    fwrite(DPP_CONNECTOR_PATH_1905, conf_dpp["signed_connector_1905"])
  end
  if conf_dpp["netaccess_key"] then
    fwrite(DPP_NET_ACCESS_KEY_PATH, conf_dpp["netaccess_key"])
  end
  if conf_dpp["csign_key"] then
    fwrite(DPP_CSIGN_KEY_PATH, conf_dpp["csign_key"])
  end
  if conf_dpp["pp_key"] then
    fwrite(DPP_PRIVACY_PROTECTION_KEY_PATH, conf_dpp["pp_key"])
  end

  local conf_radio = conf.radios
  local bss_name = nil

  -- write dpp akm and conn for radios
  _write_radio_dpp_creds(conf_radio[MAP_CONFIG_2G], MAP_CONFIG_2G)
  _write_radio_dpp_creds(conf_radio[MAP_CONFIG_5GL], MAP_CONFIG_5GL)
  _write_radio_dpp_creds(conf_radio[MAP_CONFIG_5GH], MAP_CONFIG_5GH)
end

local function _reload_wifi()
  execute("wifi reload")
end

--[[
During the reinit process, creating the interfaces in OpenWRT will cause them
to be destroyed in an ungraceful manner.(i.e without terminating ongoing
connections)
This function is meant to trigger the disconnection of the Backhaul STA from the
controller's Backhaul BSS.
--]]
local function deauth_vxd(bh_band_idx)
  execute("wpa_cli -i wlan"..bh_band_idx.."-vxd disconnect")
end

local function main_reload_2(soft)
  local conf = {}
  mapconf.fill(conf, fread(MAP_CONF_TEMPLATE))
  mapconf.fill_fromsetmib(conf, fread(MAP_SETMIB_CONF))
  mapconf.fill_fromuci(conf)
  mapconf.fill_radio(conf)
  mapconf.fill_vlan(conf)
  deauth_vxd(conf.bh_band_idx)

  mapconf.set_save_uci(conf)
  _write_dpp_creds(conf)
  execute("killall hostapd")
  mapconf.commit_uci("wireless", "rtkmap")
  print("Apply configuration from controller completed")
  _reload_wifi()
  execute(("service %s restart"):format(SERVICE_NAME))
end

local function main_chnset(s1)
  local lst = lstr.ssplit(s1, "_")
  local band, channel, bwidth, sideband = lst[1], lst[2], lst[3], lst[4]
  band = tonumber(band)
  channel = tonumber(channel)
  bwidth = tonumber(bwidth)
  sideband = tonumber(sideband)
  local radio_name = mapconf.m_band2_radioname[band]
  local prev_mode = get_prev_mode(radio_name)
  if not radio_name then return end
  if channel and channel ~= -1 then
    execute("uci set wireless."..radio_name..".channel="..channel..";uci commit")
  end
  local htmode
  if bwidth and bwidth ~= -1 and prev_mode then
    htmode = prev_mode .. mapconf.m_chw_htmode[bwidth]
  end
  if htmode then
    execute("uci set wireless."..radio_name..".htmode="..htmode..";uci commit")
  end
end

