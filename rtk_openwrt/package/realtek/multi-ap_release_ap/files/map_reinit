  end

  print(("%s %s %s %s"):format("" .. (_G.arg[0] or ""), "" .. (_G.arg[1] or ""), "" .. (_G.arg[2] or ""),
  "" .. (_G.arg[3] or "")))
  -- /usr/bin/map_reinit -f
  -- /usr/bin/map_reinit -b 0_1_0_-1

  if opts.b then
    main_chnset(opts.b)
  elseif opts.c then
    main_configstateset(opts.c)
  elseif opts.f then
    print("Need full reload!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!")
    main_reload_2(opts.l)
  elseif opts.l then
    print("Only need reload!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!")
    main_reload_2(opts.l)
  else
    print("Unknown arguments!")
  end
end

