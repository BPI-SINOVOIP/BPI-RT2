#!/usr/bin/lua

local uci = require("luci.model.uci").cursor()

local function execute(cmd)
  print(cmd)
  os.execute(cmd)
end

local function fwrite(path, s)
  if not s then return end
  local f
  f = assert(io.open(path, "w+"))
  f:write(s)
  f:close()
end

local function fread(path)
  local f, s
  f = assert(io.open(path, "r"))
  s = f:read("*all")
  f:close()
  return s
end

