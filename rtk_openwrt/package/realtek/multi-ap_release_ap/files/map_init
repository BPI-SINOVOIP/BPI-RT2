  local opts, args = require("rtk.optarg").from_opthelp(opthelp)
  if not opts then
    print("Usage: " .. _G.arg[0] .. ": [-atflv] [-c OPTARG]")
    print(opthelp)
    os.exit(1)
  end

  print(("%s %s %s %s"):format("" .. (_G.arg[0] or ""), "" .. (_G.arg[1] or ""), "" .. (_G.arg[2] or ""),
  "" .. (_G.arg[3] or "")))

  main_reload_1(opts.l)
end

main()
